;; Regression: pin down type-promotion rules for every arithmetic op.
;; Each assertion locks in the current behavior so an accidental change
;; (e.g. someone widening `+` to i64 unconditionally) breaks loudly.
;;
;; Documented rules:
;;   1. Same-width binary +/-/* preserve type; / always returns f64.
;;        (+ 5h 3h) → i16,  (+ 5i 3i) → i32,  (+ 5 3) → i64,  (+ 5.0 3.0) → f64
;;   2. Cross-width binary: wider wins.
;;        (+ i16 i32) → i32,  (+ i16 i64) → i64,  (+ i16 f64) → f64
;;   3. Comparison ops always return bool.
;;   4. Unary neg / floor / ceil preserve type.
;;   5. Unary abs preserves type (same as neg/floor/ceil).
;;   6. Math fns (round, sqrt, log, exp) always produce f64.

;; ── (1) Same-width preservation: + - *
(type (+ 5h 3h)) -- 'i16
(type (- 5h 3h)) -- 'i16
(type (* 5h 3h)) -- 'i16
(type (/ 6h 3h)) -- 'f64
(type (+ 5i 3i)) -- 'i32
(type (- 5i 3i)) -- 'i32
(type (* 5i 3i)) -- 'i32
(type (/ 6i 3i)) -- 'f64
(type (+ 5 3))   -- 'i64
(type (- 5 3))   -- 'i64
(type (* 5 3))   -- 'i64
(type (/ 6 3))   -- 'f64
(type (+ 5.0 3.0)) -- 'f64
(type (- 5.0 3.0)) -- 'f64
(type (* 5.0 3.0)) -- 'f64
(type (/ 6.0 3.0)) -- 'f64

;; vector form mirrors atomic
(type (+ [1h 2h] [3h 4h])) -- 'I16
(type (+ [1i 2i] [3i 4i])) -- 'I32
(type (+ [1 2] [3 4]))     -- 'I64
(type (+ [1.0 2.0] [3.0 4.0])) -- 'F64

;; ── (2) Cross-width: wider wins
(type (+ 5h 3i))   -- 'i32
(type (+ 5h 3))    -- 'i64
(type (+ 5i 3))    -- 'i64
(type (+ 5h 3.0))  -- 'f64
(type (+ 5i 3.0))  -- 'f64
(type (+ 5 3.0))   -- 'f64

(type (+ [1h 2h] [3i 4i])) -- 'I32
(type (+ [1h 2h] [3 4]))   -- 'I64
(type (+ [1h 2h] [3.0 4.0])) -- 'F64
(type (+ [1i 2i] [3.0 4.0])) -- 'F64

;; ── (3) Comparison always → bool
(type (== 5h 3h)) -- 'b8
(type (!= 5h 3h)) -- 'b8
(type (> 5h 3h))  -- 'b8
(type (< 5h 3h))  -- 'b8
(type (>= 5h 3h)) -- 'b8
(type (<= 5h 3h)) -- 'b8

(type (== 5h 3))   -- 'b8
(type (== 5h 3.0)) -- 'b8

(type (== [1h 2h] [3h 4h])) -- 'B8

;; ── (4) Unary preserve type: neg, floor, ceil
(neg 5h)         -- -5h
(type (neg 5h))   -- 'i16
(neg 5i)         -- -5i
(type (neg 5i))   -- 'i32
(neg 5)          -- -5
(type (neg 5))    -- 'i64
(neg 5.0)        -- -5.0
(type (neg 5.0))  -- 'f64
(neg [1h 2h])    -- [-1h -2h]
(type (neg [1h 2h])) -- 'I16
(neg [1i 2i])    -- [-1i -2i]
(type (neg [1i 2i])) -- 'I32

(floor 5h)        -- 5h
(type (floor 5h))  -- 'i16
(floor 5i)        -- 5i
(type (floor 5i))  -- 'i32
(floor 5)         -- 5
(type (floor 5))   -- 'i64
(floor 5.0)       -- 5.0
(type (floor 5.0)) -- 'f64

(ceil 5h)         -- 5h
(type (ceil 5h))  -- 'i16
(ceil 5i)         -- 5i
(type (ceil 5i))  -- 'i32
(ceil 5)          -- 5
(type (ceil 5))   -- 'i64
(ceil 5.0)        -- 5.0
(type (ceil 5.0)) -- 'f64

;; ── (5) abs preserves type (same convention as neg/floor/ceil)
(abs 5h)          -- 5h
(type (abs 5h))   -- 'i16
(abs 5i)          -- 5i
(type (abs 5i))   -- 'i32
(abs 5)           -- 5
(type (abs 5))    -- 'i64
(abs 5.0)         -- 5.0
(type (abs 5.0))  -- 'f64
(abs [1h -2h])    -- [1h 2h]
(type (abs [1h -2h])) -- 'I16
(abs [1i -2i])    -- [1i 2i]
(type (abs [1i -2i])) -- 'I32

;; ── (6) Math fns always → f64
(round 5h)         -- 5.0
(type (round 5h)) -- 'f64
(round 5i)         -- 5.0
(type (round 5i)) -- 'f64
(round 5)          -- 5.0
(type (round 5))  -- 'f64
(round 5.0)        -- 5.0
(type (round 5.0)) -- 'f64

;; sqrt(5) ≈ 2.2360679774997896
(< (abs (- (sqrt 5h) 2.236067977499790)) 0.0001) -- true
(type (sqrt 5h)) -- 'f64
(< (abs (- (sqrt 5i) 2.236067977499790)) 0.0001) -- true
(type (sqrt 5i)) -- 'f64
(< (abs (- (sqrt 5) 2.236067977499790)) 0.0001) -- true
(type (sqrt 5))  -- 'f64
(< (abs (- (sqrt 5.0) 2.236067977499790)) 0.0001) -- true
(type (sqrt 5.0)) -- 'f64

;; log(5) ≈ 1.6094379124341003 (natural log)
(< (abs (- (log 5h) 1.609437912434100)) 0.0001) -- true
(type (log 5h)) -- 'f64
(< (abs (- (log 5i) 1.609437912434100)) 0.0001) -- true
(type (log 5i)) -- 'f64
(< (abs (- (log 5) 1.609437912434100)) 0.0001) -- true
(type (log 5))  -- 'f64
(< (abs (- (log 5.0) 1.609437912434100)) 0.0001) -- true
(type (log 5.0)) -- 'f64

;; exp(5) ≈ 148.4131591025766
(< (abs (- (exp 5h) 148.4131591025766)) 0.0001) -- true
(type (exp 5h)) -- 'f64
(< (abs (- (exp 5i) 148.4131591025766)) 0.0001) -- true
(type (exp 5i)) -- 'f64
(< (abs (- (exp 5) 148.4131591025766)) 0.0001) -- true
(type (exp 5))  -- 'f64
(< (abs (- (exp 5.0) 148.4131591025766)) 0.0001) -- true
(type (exp 5.0)) -- 'f64

;; ── Mod (%) preserves type same as +/-/*
(type (% 7h 3h)) -- 'i16
(type (% 7i 3i)) -- 'i32
(type (% 7 3))   -- 'i64
(type (% 7.0 3.0)) -- 'f64
