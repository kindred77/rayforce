;; Invariants for `%` (floor-modulo).

;; range:  0 <= (% a m) < m  for positive m
(set A (- (rand 256 10000) 5000))
(set M (+ (rand 256 50) 1))
(count A) -- (sum (>= (% A M) 0))
(count A) -- (sum (< (% A M) M))

;; Euclidean identity:  a == (+ (* m (/ a m)) (% a m))
(count A) -- (sum (== A (+ (* M (/ A M)) (% A M))))

;; concrete
(% 7 3) -- 1
(% 0 5) -- 0

;; floor-mod with negative — sign follows divisor (Python semantics)
(% -10 3) -- 2
(% 10 -3) -- -2

;; mod by 1 is always 0
(% 17 1)  -- 0
(% -42 1) -- 0

;; mod by self is 0
(% 7 7) -- 0

;; ──────────────────────────────────────────────────────────────────
;; Type sweep
;; ──────────────────────────────────────────────────────────────────

(% 10h 3h) -- 1
(type (% 10h 3h)) -- 'i16
(% 10i 3i) -- 1
(type (% 10i 3i)) -- 'i32

(% [10 11 12] 3) -- [1 2 0]

;; ──────────────────────────────────────────────────────────────────
;; Null + zero divisor
;; ──────────────────────────────────────────────────────────────────

(nil? (% 0Ni 5)) -- true
(% 10 0) -- 0Nl
