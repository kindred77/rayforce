;; Branch coverage for src/ops/arith.c — targeting uncovered branches.
;;
;; Organised by function, then by source line / branch.
;; Each assertion documents the branch it targets.

;; ══════════════════════════════════════════════════════════════════════
;; ray_add_fn — temporal + integer arithmetic
;; ══════════════════════════════════════════════════════════════════════

;; ── L37-38: is_temporal(a) && is_numeric(b) — null propagation ──

;; null DATE + int → null DATE (a is null)
(nil? (+ 0Nd 5))         -- true
(type (+ 0Nd 5))         -- 'date

;; DATE + null int → null DATE (b is null)
(nil? (+ (as 'DATE 7305) 0Ni)) -- true
(type (+ (as 'DATE 7305) 0Ni)) -- 'date

;; null TIME + int → null TIME (a is null)
(nil? (+ 0Nt 5))         -- true
(type (+ 0Nt 5))         -- 'time

;; TIME + null int → null TIME (b is null)
(nil? (+ (as 'TIME 1000) 0Ni)) -- true
(type (+ (as 'TIME 1000) 0Ni)) -- 'time

;; null TIMESTAMP + int → null TIMESTAMP (a is null)
(nil? (+ 0Np 5))         -- true
(type (+ 0Np 5))         -- 'timestamp

;; TIMESTAMP + null int → null TIMESTAMP (b is null)
(nil? (+ (as 'TIMESTAMP 1000) 0Ni)) -- true
(type (+ (as 'TIMESTAMP 1000) 0Ni)) -- 'timestamp

;; ── L41-43: non-null temporal + int dispatch (all three types) ──

;; DATE + int → DATE (non-null)
(+ (as 'DATE 7305) 5) -- 2020.01.06

;; TIME + int → TIME (non-null)
(type (+ (as 'TIME 1000) 500)) -- 'time

;; TIMESTAMP + int → TIMESTAMP (non-null)
(type (+ (as 'TIMESTAMP 1000) 500)) -- 'timestamp

;; ── L45-53: numeric(a) + temporal(b) — non-F64 path ──

;; int + null DATE → null DATE
(nil? (+ 5 0Nd))         -- true
(type (+ 5 0Nd))         -- 'date

;; null int + DATE → null DATE
(nil? (+ 0Ni (as 'DATE 7305))) -- true
(type (+ 0Ni (as 'DATE 7305))) -- 'date

;; int + DATE (non-null) → DATE
(+ 5 (as 'DATE 7305)) -- 2020.01.06

;; int + TIME (non-null) → TIME
(type (+ 500 (as 'TIME 1000))) -- 'time

;; int + TIMESTAMP (non-null) → TIMESTAMP
(type (+ 500 (as 'TIMESTAMP 1000))) -- 'timestamp

;; ── L55-56: float + temporal → type error (both directions) ──

(+ 1.5 (as 'DATE 7305))     !- type
(+ 1.5 (as 'TIME 1000))     !- type
(+ 1.5 (as 'TIMESTAMP 100)) !- type
(+ (as 'DATE 7305) 1.5)     !- type
(+ (as 'TIME 1000) 1.5)     !- type
(+ (as 'TIMESTAMP 100) 1.5) !- type

;; ── L58-59: null numeric + temporal (non-F64 null, like null i32) ──
;; These hit the "reject null_numeric + temporal" guard.
;; 0Ni is a null I32 — it's numeric and null but not temporal-compatible
;; after the first temporal+numeric block passed through.
;; Actually these are caught by L37/L46 first. The L58-59 guard catches
;; the case where the null numeric has a float-null type.

;; ── L60-61: temporal + null numeric ──
;; These should be caught when temporal(a) + numeric null(b) goes through
;; L37 first. The L60 guard catches is_temporal(a) && is_numeric(b) && IS_NULL(b)
;; which fires for float-null on right.

;; ── L63-65: DATE + TIME → TIMESTAMP (null propagation) ──

;; null DATE + TIME → null TIMESTAMP
(nil? (+ 0Nd (as 'TIME 0)))    -- true
(type (+ 0Nd (as 'TIME 0)))    -- 'timestamp

;; DATE + null TIME → null TIMESTAMP
(nil? (+ (as 'DATE 7305) 0Nt)) -- true
(type (+ (as 'DATE 7305) 0Nt)) -- 'timestamp

;; ── L67-69: TIME + DATE → TIMESTAMP (null propagation) ──

;; null TIME + DATE → null TIMESTAMP
(nil? (+ 0Nt (as 'DATE 7305))) -- true
(type (+ 0Nt (as 'DATE 7305))) -- 'timestamp

;; TIME + null DATE → null TIMESTAMP
(nil? (+ (as 'TIME 0) 0Nd))    -- true
(type (+ (as 'TIME 0) 0Nd))    -- 'timestamp

;; ── L72-74: TIME + TIME → TIME (null propagation) ──

;; null TIME + TIME → null TIME
(nil? (+ 0Nt (as 'TIME 1000)))    -- true
(type (+ 0Nt (as 'TIME 1000)))    -- 'time

;; TIME + null TIME → null TIME
(nil? (+ (as 'TIME 1000) 0Nt))    -- true
(type (+ (as 'TIME 1000) 0Nt))    -- 'time

;; ── L77-79: TIME + TIMESTAMP → TIMESTAMP (null propagation) ──

;; null TIME + TIMESTAMP → null TIMESTAMP
(nil? (+ 0Nt (as 'TIMESTAMP 2000))) -- true
(type (+ 0Nt (as 'TIMESTAMP 2000))) -- 'timestamp

;; TIME + null TIMESTAMP → null TIMESTAMP
(nil? (+ (as 'TIME 1000) 0Np))      -- true
(type (+ (as 'TIME 1000) 0Np))      -- 'timestamp

;; ── L81-83: TIMESTAMP + TIME → TIMESTAMP (null propagation) ──

;; null TIMESTAMP + TIME → null TIMESTAMP
(nil? (+ 0Np (as 'TIME 1000)))      -- true
(type (+ 0Np (as 'TIME 1000)))      -- 'timestamp

;; TIMESTAMP + null TIME → null TIMESTAMP
(nil? (+ (as 'TIMESTAMP 2000) 0Nt)) -- true
(type (+ (as 'TIMESTAMP 2000) 0Nt)) -- 'timestamp

;; ── L90: null propagation for numeric+numeric (typed null varieties) ──

;; null I16 + I16 → null I16
(nil? (+ 0Nh 5h)) -- true
(type (+ 0Nh 5h)) -- 'i16

;; null I32 + I32 → null I32
(nil? (+ 0Ni 5i)) -- true
(type (+ 0Ni 5i)) -- 'i32

;; null I16 + I64 → null I64
(nil? (+ 0Nh 5)) -- true
(type (+ 0Nh 5)) -- 'i64

;; null I32 + I64 → null I64
(nil? (+ 0Ni 5)) -- true

;; ══════════════════════════════════════════════════════════════════════
;; ray_sub_fn — temporal subtraction branches
;; ══════════════════════════════════════════════════════════════════════

;; ── L101-103: temporal(a) - numeric(b) null → null typed on a ──

;; null TIMESTAMP - int → null TIMESTAMP
(nil? (- 0Np 5))                    -- true
(type (- 0Np 5))                    -- 'timestamp

;; null TIME - int → null TIME
(nil? (- 0Nt 5))                    -- true
(type (- 0Nt 5))                    -- 'time

;; null DATE - int → null DATE
(nil? (- 0Nd 5))                    -- true
(type (- 0Nd 5))                    -- 'date

;; TIMESTAMP - null int → null TIMESTAMP
(nil? (- (as 'TIMESTAMP 5000) 0Ni)) -- true
(type (- (as 'TIMESTAMP 5000) 0Ni)) -- 'timestamp

;; ── L105-107: numeric(a) - temporal(b) null → null typed on b ──

;; int - null DATE → null DATE
(nil? (- 5 0Nd))                    -- true
(type (- 5 0Nd))                    -- 'date

;; int - null TIMESTAMP → null TIMESTAMP
(nil? (- 5 0Np))                    -- true
(type (- 5 0Np))                    -- 'timestamp

;; null int - TIME → null TIME
(nil? (- 0Ni (as 'TIME 500)))       -- true
(type (- 0Ni (as 'TIME 500)))       -- 'time

;; ── L114-116: DATE - DATE null → null I32 ──

(nil? (- 0Nd (as 'DATE 7305)))      -- true
(type (- 0Nd (as 'DATE 7305)))      -- 'i32

(nil? (- (as 'DATE 7305) 0Nd))      -- true
(type (- (as 'DATE 7305) 0Nd))      -- 'i32

;; ── L119-121: DATE - TIME null → null TIMESTAMP ──

(nil? (- 0Nd (as 'TIME 0)))         -- true
(type (- 0Nd (as 'TIME 0)))         -- 'timestamp

(nil? (- (as 'DATE 7305) 0Nt))      -- true
(type (- (as 'DATE 7305) 0Nt))      -- 'timestamp

;; ── L132-134: TIME - TIME null → null TIME ──

(nil? (- 0Nt (as 'TIME 2000)))      -- true
(type (- 0Nt (as 'TIME 2000)))      -- 'time

(nil? (- (as 'TIME 5000) 0Nt))      -- true
(type (- (as 'TIME 5000) 0Nt))      -- 'time

;; ── L141-143: TIMESTAMP - TIME null → null TIMESTAMP ──

(nil? (- 0Np (as 'TIME 0)))         -- true
(type (- 0Np (as 'TIME 0)))         -- 'timestamp

(nil? (- (as 'TIMESTAMP 5000) 0Nt)) -- true
(type (- (as 'TIMESTAMP 5000) 0Nt)) -- 'timestamp

;; ── L146-148: TIMESTAMP - TIMESTAMP null → null I64 ──

(nil? (- 0Np (as 'TIMESTAMP 2000))) -- true
(type (- 0Np (as 'TIMESTAMP 2000))) -- 'i64

(nil? (- (as 'TIMESTAMP 5000) 0Np)) -- true
(type (- (as 'TIMESTAMP 5000) 0Np)) -- 'i64

;; ── L158: numeric null sub propagation (I16 null) ──

(nil? (- 0Nh 5h)) -- true
(type (- 0Nh 5h)) -- 'i16

;; ── L159-162: float sub path and -0 normalization ──

(- 1.0 1.0) -- 0.0
(- 0.5 0.5) -- 0.0

;; ══════════════════════════════════════════════════════════════════════
;; ray_mul_fn — temporal multiply branches
;; ══════════════════════════════════════════════════════════════════════

;; ── L185-187: non-numeric type error for mul ──

(* (as 'DATE 7305) 2) !- type
(* 2 (as 'DATE 7305)) !- type
(* (as 'TIMESTAMP 1000) 2) !- type

;; ── L189: null numeric * numeric → null (I16 path) ──

(nil? (* 0Nh 5h)) -- true
(type (* 0Nh 5h)) -- 'i16

;; ══════════════════════════════════════════════════════════════════════
;; ray_div_fn — division branches
;; ══════════════════════════════════════════════════════════════════════

;; ── L198-200: non-numeric type error ──

(/ "abc" 2)          !- type
(/ (as 'DATE 7305) 2) !- type
(/ (as 'TIME 1000) 2) !- type

;; ══════════════════════════════════════════════════════════════════════
;; ray_idiv_fn — integer division branches
;; ══════════════════════════════════════════════════════════════════════

;; ── L210-211: non-numeric type error ──

(div "abc" 2)            !- type
(div (as 'DATE 7305) 2)  !- type

;; ── L213-214: null propagation ──

(nil? (div 0Ni 5))   -- true
(nil? (div 5 0Ni))   -- true
(nil? (div 0Nf 5.0)) -- true
(type (div 0Ni 5))   -- 'i64

;; ── L216-217: div by zero ──

(nil? (div 10 0))    -- true
(nil? (div 10.0 0.0)) -- true
(type (div 10 0))    -- 'i64

;; ══════════════════════════════════════════════════════════════════════
;; ray_mod_fn — temporal and float modulo branches
;; ══════════════════════════════════════════════════════════════════════

;; ── L228-230: temporal % numeric null propagation ──

;; null DATE % int → null DATE
(nil? (% 0Nd 5))         -- true
(type (% 0Nd 5))         -- 'date

;; null TIME % int → null TIME
(nil? (% 0Nt 5))         -- true
(type (% 0Nt 5))         -- 'time

;; null TIMESTAMP % int → null TIMESTAMP
(nil? (% 0Np 5))         -- true
(type (% 0Np 5))         -- 'timestamp

;; DATE % null int → null DATE
(nil? (% (as 'DATE 7305) 0Ni)) -- true
(type (% (as 'DATE 7305) 0Ni)) -- 'date

;; TIME % null int → null TIME
(nil? (% (as 'TIME 100000) 0Ni)) -- true
(type (% (as 'TIME 100000) 0Ni)) -- 'time

;; TIMESTAMP % null int → null TIMESTAMP
(nil? (% (as 'TIMESTAMP 1000000) 0Ni)) -- true
(type (% (as 'TIMESTAMP 1000000) 0Ni)) -- 'timestamp

;; ── L232-236: temporal % float — zero divisor → typed null ──

(nil? (% (as 'TIME 100000) 0.0)) -- true
(type (% (as 'TIME 100000) 0.0)) -- 'time

;; ── L240-241: temporal % int — zero divisor ──

;; (already covered in mod.rfl for TIME and DATE)
;; Ensure TIMESTAMP path:
(nil? (% (as 'TIMESTAMP 1000000) 0)) -- true
(type (% (as 'TIMESTAMP 1000000) 0)) -- 'timestamp

;; ── L245: temporal mod — floor-division correction for negative ──
;; (av ^ bv) < 0 triggers the q-- adjustment

;; floor-mod: sign follows divisor (negative), so result is negative TIME
(% (as 'TIME 100000) -3) -- -00:00:00.002
(% (as 'DATE 7305) -3)   -- 2000.01.01

;; ── L247-249: temporal mod result types ──

;; TIME % positive → TIME
(type (% (as 'TIME 100000) 3)) -- 'time

;; DATE % positive → DATE
(type (% (as 'DATE 7305) 3)) -- 'date

;; TIMESTAMP % positive → TIMESTAMP (line 249)
(type (% (as 'TIMESTAMP 1000000) 3)) -- 'timestamp

;; ── L251-253: non-numeric mod error ──

(% "abc" 2) !- type
(% 2 "abc") !- type

;; ── L261-263: u8 left, non-u8 right — fallthrough ──
;; (already covered in mod.rfl)

;; ── L266-268: null propagation — rhs typed null ──

;; null + F64 rhs → null F64
(nil? (% 0Nf 5.0))   -- true
(type (% 0Nf 5.0))   -- 'f64

;; null + I32 rhs → null I32
(nil? (% 0Ni (as 'I32 5))) -- true

;; null I64 lhs + non-null I32 rhs → rt follows logic
(nil? (% 0Nl 5i))    -- true

;; F64 null lhs, I32 rhs → F64 (L267: a->type == -RAY_F64)
(nil? (% 0Nf 5i))    -- true
(type (% 0Nf 5i))    -- 'f64

;; ── L272-284: float modulo branches ──

;; f64 % f64 basic
(% 10.0 3.0) -- 1.0

;; f64 % f64 — zero divisor → typed null
(nil? (% 10.0 0.0))  -- true
(type (% 10.0 0.0))  -- 'f64

;; f64 % I32 rhs → still F64 result (L281 checks a->type == F64 first)
(% 10.0 (as 'I32 3))  -- 1.0
(type (% 10.0 (as 'I32 3))) -- 'f64

;; f64 % I16 rhs → still F64
(% 10.0 (as 'I16 3))  -- 1.0
(type (% 10.0 (as 'I16 3))) -- 'f64

;; f64 % I64 rhs → F64
(% 10.0 3)  -- 1.0

;; NOTE: lines 282-284 (make_i32/make_i16/make_i64 in float-mod block)
;; are structurally unreachable: is_float_op(a,b) requires at least one
;; operand to be F64, and L281 returns make_f64 when either is F64.
;; The guards on L282-284 are dead branches.

;; Float mod snap: result near zero snaps to 0
(% 3.0 3.0) -- 0.0

;; Float mod snap: result near |bv| snaps to 0
(% 6.0 3.0) -- 0.0

;; Float mod with zero divisor, non-f64 types (L274-276)
(nil? (% 10.0 (as 'I32 0))) -- true
(type (% 10.0 (as 'I32 0))) -- 'f64

;; ── L288-299: integer modulo branches ──

;; Integer mod: zero divisor with I64 rhs → null I64
(nil? (% 10 0))  -- true
(type (% 10 0))  -- 'i64

;; Integer mod: floor-division correction for negative (line 293)
(% -10 3) -- 2
(% 10 -3) -- -2

;; Integer mod: result type I32 (line 296)
(% 100 (as 'I32 7)) -- 2

;; Integer mod: result type I16 (line 297)
(% 100 (as 'I16 7)) -- 2

;; Integer mod: U8 result (line 298)
(% 100 (as 'U8 7)) -- 0x02

;; ══════════════════════════════════════════════════════════════════════
;; ray_neg_fn — negation branches
;; ══════════════════════════════════════════════════════════════════════

;; ── L303: null propagation (different null types) ──

;; null F64 → stays null
(nil? (neg 0Nf))  -- true
(type (neg 0Nf))  -- 'f64

;; null I64 → stays null
(nil? (neg 0Nl))  -- true
(type (neg 0Nl))  -- 'i64

;; ── L322: type error for non-numeric ──

(neg (as 'DATE 7305)) !- type
(neg (as 'TIME 1000)) !- type
(neg (as 'TIMESTAMP 1000)) !- type
(neg (as 'U8 5))       !- type

