(type (pow 0Nl 0Nl))  -- 'f64

(nil? (pow 0Nf 0Nf))  -- true
(type (pow 0Nf 0Nf))  -- 'f64

;; ── L407-408: non-numeric → type error ──

(pow (as 'DATE 7305) 2) !- type
