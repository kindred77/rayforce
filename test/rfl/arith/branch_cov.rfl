(pow (as 'TIME 1000) 2) !- type

;; ══════════════════════════════════════════════════════════════════════
;; Cross-cutting: numeric null propagation through null_for_promoted
;; (internal.h L139-148) — make sure each width-pair's null branch fires
;; ══════════════════════════════════════════════════════════════════════

;; I16 + null I16 → null I16 (L146-147)
(nil? (+ 5h 0Nh)) -- true
(type (+ 5h 0Nh)) -- 'i16

;; I32 + null I32 → null I32 (L144-145)
(nil? (+ 5i 0Ni)) -- true
(type (+ 5i 0Ni)) -- 'i32

;; I64 + null I64 → null I64 (L142-143)
(nil? (+ 5 0Nl)) -- true
(type (+ 5 0Nl)) -- 'i64

;; F64 + null F64 → null F64 (L140-141)
(nil? (+ 5.0 0Nf)) -- true
(type (+ 5.0 0Nf)) -- 'f64

;; Cross-width null: I16 + null I32 → null I32
(nil? (+ 5h 0Ni)) -- true
(type (+ 5h 0Ni)) -- 'i32

;; Cross-width null: I16 + null I64 → null I64
(nil? (+ 5h 0Nl)) -- true
(type (+ 5h 0Nl)) -- 'i64

;; Cross-width null: I32 + null I64 → null I64
(nil? (+ 5i 0Nl)) -- true
(type (+ 5i 0Nl)) -- 'i64

;; ══════════════════════════════════════════════════════════════════════
;; Additional sub branches — promote_int_type_right paths
;; ══════════════════════════════════════════════════════════════════════

;; sub result type follows RIGHT operand's width (promote_int_type_right)
(type (- 10 5i)) -- 'i32
(type (- 10 5h)) -- 'i16
(type (- 10 (as 'U8 3))) -- 'u8

;; When right is not a recognized int type, fall through to left
;; (but all numeric types are recognized, so just test coverage of each)
(type (- 10h 5)) -- 'i64
(type (- 10i 5)) -- 'i64

;; ══════════════════════════════════════════════════════════════════════
;; Additional add branches — promote_int_type paths
;; ══════════════════════════════════════════════════════════════════════

;; U8 + U8 → U8 (L162)
(+ (as 'U8 3) (as 'U8 4)) -- 0x07
(type (+ (as 'U8 3) (as 'U8 4))) -- 'u8

;; U8 + I16 → I16 (L163)
(+ (as 'U8 3) 4h) -- 7
(type (+ (as 'U8 3) 4h)) -- 'i16

;; I16 + U8 → I16 (L163 symmetric)
(+ 3h (as 'U8 4)) -- 7
(type (+ 3h (as 'U8 4))) -- 'i16

;; U8 + I64 → I64 (L163 default branch: neither is I16)
(+ (as 'U8 3) 4) -- 7
(type (+ (as 'U8 3) 4)) -- 'i64

;; ══════════════════════════════════════════════════════════════════════
;; Temporal % float non-zero-divisor (L232-236 non-zero path)
;; ══════════════════════════════════════════════════════════════════════

;; temporal % float where float truncates to non-zero int
(type (% (as 'TIME 100000) 3.0)) -- 'time
(type (% (as 'DATE 7305) 5.0)) -- 'date
(type (% (as 'TIMESTAMP 1000000) 7.0)) -- 'timestamp

;; temporal % float where float truncates to zero (e.g. 0.5 → 0)
(nil? (% (as 'TIME 100000) 0.5)) -- true
(type (% (as 'TIME 100000) 0.5)) -- 'time

;; ══════════════════════════════════════════════════════════════════════
;; Float mod snap branches (L280)
;; ══════════════════════════════════════════════════════════════════════

;; Negative divisor snap: result near |bv| → bv > 0 ? 0.0 : -0.0
(% 6.0 -3.0) -- 0.0
(% -6.0 3.0) -- 0.0
(% -6.0 -3.0) -- 0.0

;; ══════════════════════════════════════════════════════════════════════
;; STRUCTURAL NOTES — unreachable branches in arith.c
;; ══════════════════════════════════════════════════════════════════════
;;
;; L58-59 (add): `is_numeric(a) && RAY_ATOM_IS_NULL(a) && is_temporal(b)`
;;   Unreachable: non-F64 null numerics are caught by L45-47 (which
;;   matches `is_numeric(a) && a->type != -RAY_F64 && is_temporal(b)`
;;   then L46 null-check). F64 nulls are caught by L55 (`a->type == -RAY_F64
;;   && is_temporal(b)` → error). No path reaches L58.
;;
;; L60-61 (add): `is_temporal(a) && is_numeric(b) && RAY_ATOM_IS_NULL(b)`
;;   Unreachable: non-F64 null numerics caught by L36-38. F64 caught by L55.
;;
;; L282-284 (mod): float-mod I32/I16/I64 result branches
;;   Unreachable: `is_float_op(a,b)` (L272) requires at least one F64 operand.
;;   L281 checks `b->type == -RAY_F64 || a->type == -RAY_F64` — same condition.
;;   So L281 always returns, and L282-284 are dead code.
