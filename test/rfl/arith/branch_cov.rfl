(nil? (log 0Nf))  -- true
(type (log 0Nf))  -- 'f64

(nil? (log 0Nl))  -- true
(type (log 0Nl))  -- 'f64

(nil? (log 0Nh))  -- true
(type (log 0Nh))  -- 'f64

(nil? (log 0Ni))  -- true
(type (log 0Ni))  -- 'f64

;; ── L383: is_numeric(x) integer input ──
;; log(5) ≈ 1.6094379124341003 (natural log)
(< (abs (- (log 5)  1.609437912434100)) 0.0001) -- true
(type (log 5))  -- 'f64
(< (abs (- (log 5h) 1.609437912434100)) 0.0001) -- true
(type (log 5h)) -- 'f64
(< (abs (- (log 5i) 1.609437912434100)) 0.0001) -- true
(type (log 5i)) -- 'f64

