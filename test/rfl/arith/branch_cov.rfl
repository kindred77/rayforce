(nil? (round 0Nf))  -- true
(type (round 0Nf))  -- 'f64

(nil? (round 0Nl))  -- true
(type (round 0Nl))  -- 'f64

(nil? (round 0Nh))  -- true
(type (round 0Nh))  -- 'f64

(nil? (round 0Ni))  -- true
(type (round 0Ni))  -- 'f64

;; ── L329: is_numeric(x) for int (not f64) input ──

(round 5h) -- 5.0
(round 5i) -- 5.0

;; ── L330: type error ──

(round (as 'DATE 7305)) !- type
(round (as 'TIME 1000)) !- type

