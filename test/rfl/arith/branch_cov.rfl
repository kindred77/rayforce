(nil? (sqrt 0Nl))  -- true
(type (sqrt 0Nl))  -- 'f64

(nil? (sqrt 0Nh))  -- true
(type (sqrt 0Nh))  -- 'f64

(nil? (sqrt 0Ni))  -- true
(type (sqrt 0Ni))  -- 'f64

