;; Invariants for `/` (true division; always f64 result).

;; identity: (/ a 1) == a
(set A (as 'F64 (- (rand 256 200000) 100000)))
(count A) -- (sum (== (/ A 1) A))

;; (/ (* a b) b) == a  for non-zero b
(set A (as 'F64 (- (rand 256 200) 100)))
(set B (as 'F64 (+ (rand 256 10) 1)))
(count A) -- (sum (== (/ (* A B) B) A))

;; true division
(/ 7 2) -- 3.5
(/ 10.0 3.0) -- 3.3333333333333335

;; negative operands keep true division semantics
(/ -10 4)  -- -2.5
(/ 10 -4)  -- -2.5
(/ -10 -4) -- 2.5

;; divide-by-zero yields typed null
(/ 5 0)  -- 0Nf
(/ 10 0) -- 0Nf

;; floats — Rayforce folds IEEE +Inf / NaN outcomes back to typed null
(nil? (/ 1.0 0.0)) -- true
(nil? (/ 0.0 0.0)) -- true

;; const-fold of div-by-zero must agree with the runtime path
;; (regression for the optimizer doing the fold at compile time)
(set X 1.0)
(nil? (/ X 0.0)) -- true
(== (nil? (/ 1 0)) (nil? (/ X 0))) -- true
(== (nil? (/ 1.0 0.0)) (nil? (/ X 0.0))) -- true

;; ──────────────────────────────────────────────────────────────────
;; Type sweep — narrow ints / float / cross-width
;; ──────────────────────────────────────────────────────────────────

(/ 6h 2h) -- 3.0
(type (/ 6h 2h)) -- 'f64
(/ 6i 2i) -- 3.0
(type (/ 6i 2i)) -- 'f64
(/ 10.0 4.0) -- 2.5
(type (/ 6.0 2.0)) -- 'f64
(/ [12 15 18] 3) -- [4.0 5.0 6.0]

;; ──────────────────────────────────────────────────────────────────
;; Null propagation
;; ──────────────────────────────────────────────────────────────────

(nil? (/ 0Ni 5))   -- true
(nil? (/ 5 0Ni))   -- true
(nil? (/ 0Nf 5.0)) -- true
