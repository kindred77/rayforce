;; B3 Part 2: inside a query, a LITERAL symbol naming a from-table column
;; resolves to that column.  Outside a query a literal symbol stays literal
;; (covered by test/rfl/lang/symbol_quote_semantics.rfl).
;;
;; Tick `'col` is already a literal symbol (ATTR_QUOTED set), so these forms
;; exercise the post-Task-2 contract directly without needing (quote x) to be
;; a literal yet.
;;
;; CONTRACT: a literal -RAY_SYM resolves to a from-table COLUMN only — never
;; to a lambda/let local (no env capture), and only while a query is active.
;; A literal that names no column stays a constant symbol.

(set Tlit (table [g price] (list ['a 'a 'b] [10.0 20.0 30.0])))

;; literal in projection -> resolves to the column
(at (select {o: 'price from: Tlit}) 'o) -- [10.0 20.0 30.0]

;; literal in where -> resolves to the column
(count (select {from: Tlit where: (> 'price 15.0)})) -- 2

;; literal in by -> resolves to the column (2 groups: a, b)
(count (select {n: (count price) from: Tlit by: 'g})) -- 2

;; a literal that names NO column stays a constant symbol, broadcast per row
(at (select {o: 'price tag: 'nope from: Tlit}) 'tag) -- ['nope 'nope 'nope]

;; dynamic idiom: a literal symbol carried in a variable, assembled into a
;; call at runtime and eval'd inside the query, still resolves to the column.
;; Groups by g: a -> [10.0 20.0], b -> [30.0].
(set c 'price)
(at (at (select {o: (eval (list + c 0.0)) from: Tlit by: g}) 'o) 0) -- [10.0 20.0]
(at (at (select {o: (eval (list + c 0.0)) from: Tlit by: g}) 'o) 1) -- [30.0]

;; A literal symbol that collides with a lambda FORMAL inside a query is NOT
;; captured as the formal: it resolves to the matching column instead.  Here
;; the lambda formal is named `price`; applying it with arg 999.0 must still
;; project the `price` COLUMN (because 'price is a literal, column-scoped),
;; never the formal value 999.0.
(at (select {o: ((fn [price] 'price) 999.0) from: Tlit}) 'o) -- [10.0 20.0 30.0]

;; --- regression: count-select fast path must agree with materialised select.
;; T2 has both a SYM column `s` and a BOOL column `b`.  `'b` names a column,
;; so inside the query `(== s 'b)` compares the sym column against the bool
;; column (0 matches) — the in-query collision rule.  The count fast path
;; (try_count_simple_compare) and the materialised path MUST return the same
;; value; pin BOTH to 0 so a future divergence fails the suite.
(set T2 (table [s b] (list ['a 'b 'c 'a] [true false true false])))
(count (select {from: T2 where: (== s 'b)})) -- 0
(set R2 (select {from: T2 where: (== s 'b)}))
(count R2) -- 0

;; --- regression: a literal `by:` symbol naming NO column must produce a
;; clean column-not-found error (domain) — the SAME as a bare `by: nonexistent`
;; — never a UBSan crash from ray_elem_size on a literal symbol.
(select {n: (count price) from: Tlit by: 'nope}) !- domain
(select {n: (count price) from: Tlit by: nope}) !- domain

;; --- AST-shape boundary: `(quote x)` is value-equivalent to the tick form
;; `'x` (both literal symbols), but the two are different AST SHAPES — `'x` is
;; a literal atom, `(quote x)` is a special-form CALL node.  Part 2 resolves a
;; literal -RAY_SYM ATOM to a column; it does not unwrap a `(quote col)` call
;; node written inline as a query operand.  So an inline `(quote price)` in a
;; projection stays the literal symbol, while the tick form `'price` resolves
;; (see line 16).  The dynamic-query idiom builds the query as DATA, so
;; `(quote price)` is evaluated to the literal atom `'price` BEFORE it becomes
;; an operand — that atom then resolves, which is why the idiom works.
(== 'price (quote price)) -- true
(at (select {o: (quote price) from: Tlit}) 'o) -- ['price 'price 'price]

;; --- regression (fix: (quote X) in a WHERE/DAG predicate).  Before the fix
;; the (quote X) CALL form reaching compile_expr_dag returned NULL, so an
;; inline (quote x) worked in a projection (eval fallback) but ERRORED in a
;; WHERE predicate ("WHERE predicate not supported by DAG compiler").  It now
;; folds to the literal symbol — WITHOUT the in-query column-shadow rule, so it
;; stays the literal even when it names a column (the AST-shape boundary above).
;; T2 has SYM col `s` (['a 'b 'c 'a]) and BOOL col `b`.
;;   (quote b): literal 'b  -> (== s 'b-literal) matches the 'b row     -> 1
;;   'b (tick): resolves to col b -> (== s b) sym-vs-bool               -> 0
(count (select {from: T2 where: (== s (quote b))})) -- 1
(count (select {from: T2 where: (== s 'b)})) -- 0
;; a symbol naming NO column: (quote a) and 'a agree (both literal)     -> 2
(count (select {from: T2 where: (== s (quote a))})) -- 2
(count (select {from: T2 where: (== s 'a)})) -- 2
;; and-chained predicate operand also folds (no longer "not supported")
(count (select {from: T2 where: (and (== s (quote a)) (== s 'a))})) -- 2
