(at r256v 'k255) -- [1 2]

;; ── 300-key by-DICT with a sum agg: 299 constant keys k000..k298 (all 1) +
;; a discriminator key disc, plus sm: (sum v).  Bare-ref keys are OP_SCANs and
;; an agg is present, so this routes through the DAG GROUP -> v2 agg engine
;; (not the distinct path).  Serial exec_group_v2_run at nrows=2 exercises its
;; carved key_cols[] and agg_group_keys' carved key-data table at 300 keys.
;; The disc key sits at tuple position 299 (>255): a mod-256 key count would
;; stop before it and MERGE the two rows into one group, so count 2 and
;; sum [10 30] both break under any uint8 wrap.  Table built via take/concat. ──
(set t300d (table [k000 k001 k002 k003 k004 k005 k006 k007 k008 k009 k010 k011 k012 k013 k014 k015 k016 k017 k018 k019 k020 k021 k022 k023 k024 k025 k026 k027 k028 k029 k030 k031 k032 k033 k034 k035 k036 k037 k038 k039 k040 k041 k042 k043 k044 k045 k046 k047 k048 k049 k050 k051 k052 k053 k054 k055 k056 k057 k058 k059 k060 k061 k062 k063 k064 k065 k066 k067 k068 k069 k070 k071 k072 k073 k074 k075 k076 k077 k078 k079 k080 k081 k082 k083 k084 k085 k086 k087 k088 k089 k090 k091 k092 k093 k094 k095 k096 k097 k098 k099 k100 k101 k102 k103 k104 k105 k106 k107 k108 k109 k110 k111 k112 k113 k114 k115 k116 k117 k118 k119 k120 k121 k122 k123 k124 k125 k126 k127 k128 k129 k130 k131 k132 k133 k134 k135 k136 k137 k138 k139 k140 k141 k142 k143 k144 k145 k146 k147 k148 k149 k150 k151 k152 k153 k154 k155 k156 k157 k158 k159 k160 k161 k162 k163 k164 k165 k166 k167 k168 k169 k170 k171 k172 k173 k174 k175 k176 k177 k178 k179 k180 k181 k182 k183 k184 k185 k186 k187 k188 k189 k190 k191 k192 k193 k194 k195 k196 k197 k198 k199 k200 k201 k202 k203 k204 k205 k206 k207 k208 k209 k210 k211 k212 k213 k214 k215 k216 k217 k218 k219 k220 k221 k222 k223 k224 k225 k226 k227 k228 k229 k230 k231 k232 k233 k234 k235 k236 k237 k238 k239 k240 k241 k242 k243 k244 k245 k246 k247 k248 k249 k250 k251 k252 k253 k254 k255 k256 k257 k258 k259 k260 k261 k262 k263 k264 k265 k266 k267 k268 k269 k270 k271 k272 k273 k274 k275 k276 k277 k278 k279 k280 k281 k282 k283 k284 k285 k286 k287 k288 k289 k290 k291 k292 k293 k294 k295 k296 k297 k298 disc v] (concat (take (list [1 1]) 299) (list [1 2] [10 30]))))
(set r300d (select {from: t300d sm: (sum v) by: {k000: k000 k001: k001 k002: k002 k003: k003 k004: k004 k005: k005 k006: k006 k007: k007 k008: k008 k009: k009 k010: k010 k011: k011 k012: k012 k013: k013 k014: k014 k015: k015 k016: k016 k017: k017 k018: k018 k019: k019 k020: k020 k021: k021 k022: k022 k023: k023 k024: k024 k025: k025 k026: k026 k027: k027 k028: k028 k029: k029 k030: k030 k031: k031 k032: k032 k033: k033 k034: k034 k035: k035 k036: k036 k037: k037 k038: k038 k039: k039 k040: k040 k041: k041 k042: k042 k043: k043 k044: k044 k045: k045 k046: k046 k047: k047 k048: k048 k049: k049 k050: k050 k051: k051 k052: k052 k053: k053 k054: k054 k055: k055 k056: k056 k057: k057 k058: k058 k059: k059 k060: k060 k061: k061 k062: k062 k063: k063 k064: k064 k065: k065 k066: k066 k067: k067 k068: k068 k069: k069 k070: k070 k071: k071 k072: k072 k073: k073 k074: k074 k075: k075 k076: k076 k077: k077 k078: k078 k079: k079 k080: k080 k081: k081 k082: k082 k083: k083 k084: k084 k085: k085 k086: k086 k087: k087 k088: k088 k089: k089 k090: k090 k091: k091 k092: k092 k093: k093 k094: k094 k095: k095 k096: k096 k097: k097 k098: k098 k099: k099 k100: k100 k101: k101 k102: k102 k103: k103 k104: k104 k105: k105 k106: k106 k107: k107 k108: k108 k109: k109 k110: k110 k111: k111 k112: k112 k113: k113 k114: k114 k115: k115 k116: k116 k117: k117 k118: k118 k119: k119 k120: k120 k121: k121 k122: k122 k123: k123 k124: k124 k125: k125 k126: k126 k127: k127 k128: k128 k129: k129 k130: k130 k131: k131 k132: k132 k133: k133 k134: k134 k135: k135 k136: k136 k137: k137 k138: k138 k139: k139 k140: k140 k141: k141 k142: k142 k143: k143 k144: k144 k145: k145 k146: k146 k147: k147 k148: k148 k149: k149 k150: k150 k151: k151 k152: k152 k153: k153 k154: k154 k155: k155 k156: k156 k157: k157 k158: k158 k159: k159 k160: k160 k161: k161 k162: k162 k163: k163 k164: k164 k165: k165 k166: k166 k167: k167 k168: k168 k169: k169 k170: k170 k171: k171 k172: k172 k173: k173 k174: k174 k175: k175 k176: k176 k177: k177 k178: k178 k179: k179 k180: k180 k181: k181 k182: k182 k183: k183 k184: k184 k185: k185 k186: k186 k187: k187 k188: k188 k189: k189 k190: k190 k191: k191 k192: k192 k193: k193 k194: k194 k195: k195 k196: k196 k197: k197 k198: k198 k199: k199 k200: k200 k201: k201 k202: k202 k203: k203 k204: k204 k205: k205 k206: k206 k207: k207 k208: k208 k209: k209 k210: k210 k211: k211 k212: k212 k213: k213 k214: k214 k215: k215 k216: k216 k217: k217 k218: k218 k219: k219 k220: k220 k221: k221 k222: k222 k223: k223 k224: k224 k225: k225 k226: k226 k227: k227 k228: k228 k229: k229 k230: k230 k231: k231 k232: k232 k233: k233 k234: k234 k235: k235 k236: k236 k237: k237 k238: k238 k239: k239 k240: k240 k241: k241 k242: k242 k243: k243 k244: k244 k245: k245 k246: k246 k247: k247 k248: k248 k249: k249 k250: k250 k251: k251 k252: k252 k253: k253 k254: k254 k255: k255 k256: k256 k257: k257 k258: k258 k259: k259 k260: k260 k261: k261 k262: k262 k263: k263 k264: k264 k265: k265 k266: k266 k267: k267 k268: k268 k269: k269 k270: k270 k271: k271 k272: k272 k273: k273 k274: k274 k275: k275 k276: k276 k277: k277 k278: k278 k279: k279 k280: k280 k281: k281 k282: k282 k283: k283 k284: k284 k285: k285 k286: k286 k287: k287 k288: k288 k289: k289 k290: k290 k291: k291 k292: k292 k293: k293 k294: k294 k295: k295 k296: k296 k297: k297 k298: k298 disc: disc}}))
(count (at r300d 'disc)) -- 2
(at r300d 'disc) -- [1 2]
(at r300d 'sm) -- [10 30]

;; ── 17-key PARALLEL radix scatter: >16 keys through the high-row v2 path that
;; packs each row's keys via the per-worker kv-staging carve (agg_engine.c
;; agg_radix_scatter_one).  k00 is unique per row (70000 distinct) so the card
;; estimate exceeds T_ROUTE and the router takes exec_group_v2_parallel_radix;
;; k01..k16 are constant.  Every group has one member, so sum(v)=that row's v;
;; summed over all groups = sum(til 70000) = 69999*70000/2 = 2449965000, with
;; exactly 70000 groups.  Guards the unbounded-key radix kv carve under ASan. ──
(set t17r (table [k00 k01 k02 k03 k04 k05 k06 k07 k08 k09 k10 k11 k12 k13 k14 k15 k16 v] (list (til 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (take [1] 70000) (til 70000))))
(set r17r (select {from: t17r sm: (sum v) by: ['k00 'k01 'k02 'k03 'k04 'k05 'k06 'k07 'k08 'k09 'k10 'k11 'k12 'k13 'k14 'k15 'k16]}))
(count (at r17r 'k00)) -- 70000
(sum (at r17r 'sm)) -- 2449965000
;; ── asof/window-join right-column overflow, GENUINE regression probe:
;; exec_window_join's right_out_idx[] (src/ops/join.c) was a fixed
;; int64_t[256] filled by a loop over the RIGHT table's column count
;; (right_ncols), skipping only the time key (and any eq keys) — a right
;; table with >256 columns overflows it. WR below has 260 columns (Time +
;; d001..d259); only Time is the join key, so the loop writes
;; right_out_count = 259 entries into what was a 256-slot array, 3 past
;; the old cap. ASan (pre-fix): stack-buffer-overflow WRITE in
;; exec_window_join, join.c:3029.
;; d001..d258 all share one replicated filler column ([0]) — built via
;; (take (list [0]) 258) so the literal itself stays small (`list`/table
;; literals are capped at 64 args by the VM's calln opcodes; the bracket
;; name-vector literal below is parsed directly by the lexer with its own
;; much larger cap, so a 260-symbol names vector is fine, but the *values*
;; list has to be built via take+concat instead of a 260-arg `list` call).
;; d259 — past the former 256-column boundary — carries a distinct value
;; (777) precisely so a truncation/overflow that merely drops or corrupts
;; trailing columns (rather than crashing outright) still surfaces as a
;; wrong value here instead of silently passing.
(set wj_names [Time d001 d002 d003 d004 d005 d006 d007 d008 d009 d010 d011 d012 d013 d014 d015 d016 d017 d018 d019 d020 d021 d022 d023 d024 d025 d026 d027 d028 d029 d030 d031 d032 d033 d034 d035 d036 d037 d038 d039 d040 d041 d042 d043 d044 d045 d046 d047 d048 d049 d050 d051 d052 d053 d054 d055 d056 d057 d058 d059 d060 d061 d062 d063 d064 d065 d066 d067 d068 d069 d070 d071 d072 d073 d074 d075 d076 d077 d078 d079 d080 d081 d082 d083 d084 d085 d086 d087 d088 d089 d090 d091 d092 d093 d094 d095 d096 d097 d098 d099 d100 d101 d102 d103 d104 d105 d106 d107 d108 d109 d110 d111 d112 d113 d114 d115 d116 d117 d118 d119 d120 d121 d122 d123 d124 d125 d126 d127 d128 d129 d130 d131 d132 d133 d134 d135 d136 d137 d138 d139 d140 d141 d142 d143 d144 d145 d146 d147 d148 d149 d150 d151 d152 d153 d154 d155 d156 d157 d158 d159 d160 d161 d162 d163 d164 d165 d166 d167 d168 d169 d170 d171 d172 d173 d174 d175 d176 d177 d178 d179 d180 d181 d182 d183 d184 d185 d186 d187 d188 d189 d190 d191 d192 d193 d194 d195 d196 d197 d198 d199 d200 d201 d202 d203 d204 d205 d206 d207 d208 d209 d210 d211 d212 d213 d214 d215 d216 d217 d218 d219 d220 d221 d222 d223 d224 d225 d226 d227 d228 d229 d230 d231 d232 d233 d234 d235 d236 d237 d238 d239 d240 d241 d242 d243 d244 d245 d246 d247 d248 d249 d250 d251 d252 d253 d254 d255 d256 d257 d258 d259])
(set wj_filler [0])
(set wj_last [777])
(set wj_cols (concat (list [10:00:00.000]) (concat (take (list wj_filler) 258) (list wj_last))))
(set WR (table wj_names wj_cols))
(set WL (table [Time V] (list [10:00:01.000] [1.0])))
(set wj_out (asof-join [Time] WL WR))
(count (at wj_out 'd259)) -- 1
(at wj_out 'd259) -- [777]

;; ══════════════════════════════════════════════════════════════════
;; cut-3: window-join eq-key / agg-count carves (retire WJ_MAX_AGG [16])
;; The 5-arg window-join fast path computed n_eq unbounded but filled
;; fixed [16]/[WJ_MAX_AGG] arrays with ungated e < n_eq loops (ASan
;; stack-buffer-overflow at 18 keys) and silently dropped aggs past 16.
;; ══════════════════════════════════════════════════════════════════

;; ── 17 equality keys (18-key vector, n_eq=17 > former [16] cap).  GENUINE
;; partitioning oracle (review gap: an all-constant-key sentinel can't tell
;; a correct 17-key partition from a truncated eq count that collapses to a
;; single partition, since a single 'a' partition already IS the answer).
;; Here k01..k16 are constant 'a for both left rows (so they alone would
;; merge everything into one partition), and ONLY the 17th key partitions:
;; row0 -> k17='p, row1 -> k17='q. R17 mirrors that: 3 'p' rows carrying the
;; ORIGINAL 1-key oracle's bids [99 100 101] at [00:00 00:02 00:04], and 3
;; 'q' rows carrying LOW bids [1 2 3] at the same times — deliberately below
;; every 'p' bid, so if a regression silently drops k17 (e.g. an eq-count
;; truncation) the merged partition's min would leak a 'q' value into row0's
;; result. Verified empirically against a k17-dropped call on this exact
;; fixture: it returns [1 2] instead of the correct [99 2].
;; Oracle (per-partition, unaffected by the other group):
;;  row0 (partition 'p', Time=10:00:01, window=[09:59:59,10:00:03]):
;;   identical to the original single-group derivation -> min=99 both modes.
;;  row1 (partition 'q', Time=10:00:05, window=[10:00:03,10:00:07]):
;;   mode0 (prevailing quote): lb seeds from the last 'q' row with time<=lo
;;   (10:00:02, bid=2), ub runs to the end (all q times<=hi) -> range={2,3}
;;   -> min=2.  mode1 (strict, time>=lo): lb is the first 'q' row with
;;   time>=10:00:03, i.e. 10:00:04 (bid=3) -> range={3} -> min=3.
(set L17 (table [k01 k02 k03 k04 k05 k06 k07 k08 k09 k10 k11 k12 k13 k14 k15 k16 k17 Time V] (list [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [a a] [p q] [10:00:01.000 10:00:05.000] [100 200])))
(set R17 (table [k01 k02 k03 k04 k05 k06 k07 k08 k09 k10 k11 k12 k13 k14 k15 k16 k17 Time Bid] (list [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [a a a a a a] [p p p q q q] [10:00:00.000 10:00:02.000 10:00:04.000 10:00:00.000 10:00:02.000 10:00:04.000] [99 100 101 1 2 3])))
(set iv17 (map-left + [-2000 2000] (at L17 'Time)))
(at (window-join [k01 k02 k03 k04 k05 k06 k07 k08 k09 k10 k11 k12 k13 k14 k15 k16 k17 Time] iv17 L17 R17 {minBid: (min Bid)}) 'minBid) -- [99 2]
(at (window-join1 [k01 k02 k03 k04 k05 k06 k07 k08 k09 k10 k11 k12 k13 k14 k15 k16 k17 Time] iv17 L17 R17 {minBid: (min Bid)}) 'minBid) -- [99 3]

;; ── 17 aggregates. Pre-fix the collection loop `n_agg < WJ_MAX_AGG` silently
;; DROPPED the 17th agg — result had 19 cols not 20 and 'a17 was absent.
(set tr17 (table [Sym Time Price] (list [x x x] [12:00:01 12:00:04 12:00:06] [89.17 70.5 80.54])))
(set qu17 (table [Sym Time Size] (list [x x x x x x x x x x] [12:00:00 12:00:01 12:00:02 12:00:03 12:00:04 12:00:05 12:00:06 12:00:07 12:00:08 12:00:09] [928 528 648 914 918 626 577 817 620 698])))
(set ivq17 (map-left + [-1000 1000] (at tr17 'Time)))
(set rq17 (window-join [Sym Time] ivq17 tr17 qu17 {a01: (min Size) a02: (min Size) a03: (min Size) a04: (min Size) a05: (min Size) a06: (min Size) a07: (min Size) a08: (min Size) a09: (min Size) a10: (min Size) a11: (min Size) a12: (min Size) a13: (min Size) a14: (min Size) a15: (min Size) a16: (min Size) a17: (max Size)}))
(at (meta rq17) 'len) -- 20
(at rq17 'a17) -- [928 918 817]

;; ── 256 equality keys (257-key vector, n_eq=256) — exact-size eq carve, far
;; past the former cap.  GENUINE partitioning oracle (same review gap as the
;; 17-key sentinel above): k001..k255 are constant int 1 for every row, and
;; ONLY k256 partitions: L row0 -> k256=1, row1 -> k256=2.  R256 carries 3
;; rows per group at the ORIGINAL [00:00 00:02 00:04] times — group 1 with
;; the original bids [99 100 101], group 2 with LOW bids [1 2 3], again
;; strictly below every group-1 bid so a truncation that drops k256 (over-
;; matching into one partition) leaks a group-2 value into row0's min.
;; Oracle mirrors the 17-key derivation exactly (identical time geometry):
;; row0 (group 1) -> min=99 (unaffected by group 2); row1 (group 2, mode0
;; prevailing-quote) -> lb seeds from the last group-2 row with time<=lo
;; (10:00:02, bid=2), ub runs to the end -> range={2,3} -> min=2.
(set L256 (table [k001 k002 k003 k004 k005 k006 k007 k008 k009 k010 k011 k012 k013 k014 k015 k016 k017 k018 k019 k020 k021 k022 k023 k024 k025 k026 k027 k028 k029 k030 k031 k032 k033 k034 k035 k036 k037 k038 k039 k040 k041 k042 k043 k044 k045 k046 k047 k048 k049 k050 k051 k052 k053 k054 k055 k056 k057 k058 k059 k060 k061 k062 k063 k064 k065 k066 k067 k068 k069 k070 k071 k072 k073 k074 k075 k076 k077 k078 k079 k080 k081 k082 k083 k084 k085 k086 k087 k088 k089 k090 k091 k092 k093 k094 k095 k096 k097 k098 k099 k100 k101 k102 k103 k104 k105 k106 k107 k108 k109 k110 k111 k112 k113 k114 k115 k116 k117 k118 k119 k120 k121 k122 k123 k124 k125 k126 k127 k128 k129 k130 k131 k132 k133 k134 k135 k136 k137 k138 k139 k140 k141 k142 k143 k144 k145 k146 k147 k148 k149 k150 k151 k152 k153 k154 k155 k156 k157 k158 k159 k160 k161 k162 k163 k164 k165 k166 k167 k168 k169 k170 k171 k172 k173 k174 k175 k176 k177 k178 k179 k180 k181 k182 k183 k184 k185 k186 k187 k188 k189 k190 k191 k192 k193 k194 k195 k196 k197 k198 k199 k200 k201 k202 k203 k204 k205 k206 k207 k208 k209 k210 k211 k212 k213 k214 k215 k216 k217 k218 k219 k220 k221 k222 k223 k224 k225 k226 k227 k228 k229 k230 k231 k232 k233 k234 k235 k236 k237 k238 k239 k240 k241 k242 k243 k244 k245 k246 k247 k248 k249 k250 k251 k252 k253 k254 k255 k256 Time V] (concat (take (list [1 1]) 255) (list [1 2] [10:00:01.000 10:00:05.000] [100 200]))))
(set R256 (table [k001 k002 k003 k004 k005 k006 k007 k008 k009 k010 k011 k012 k013 k014 k015 k016 k017 k018 k019 k020 k021 k022 k023 k024 k025 k026 k027 k028 k029 k030 k031 k032 k033 k034 k035 k036 k037 k038 k039 k040 k041 k042 k043 k044 k045 k046 k047 k048 k049 k050 k051 k052 k053 k054 k055 k056 k057 k058 k059 k060 k061 k062 k063 k064 k065 k066 k067 k068 k069 k070 k071 k072 k073 k074 k075 k076 k077 k078 k079 k080 k081 k082 k083 k084 k085 k086 k087 k088 k089 k090 k091 k092 k093 k094 k095 k096 k097 k098 k099 k100 k101 k102 k103 k104 k105 k106 k107 k108 k109 k110 k111 k112 k113 k114 k115 k116 k117 k118 k119 k120 k121 k122 k123 k124 k125 k126 k127 k128 k129 k130 k131 k132 k133 k134 k135 k136 k137 k138 k139 k140 k141 k142 k143 k144 k145 k146 k147 k148 k149 k150 k151 k152 k153 k154 k155 k156 k157 k158 k159 k160 k161 k162 k163 k164 k165 k166 k167 k168 k169 k170 k171 k172 k173 k174 k175 k176 k177 k178 k179 k180 k181 k182 k183 k184 k185 k186 k187 k188 k189 k190 k191 k192 k193 k194 k195 k196 k197 k198 k199 k200 k201 k202 k203 k204 k205 k206 k207 k208 k209 k210 k211 k212 k213 k214 k215 k216 k217 k218 k219 k220 k221 k222 k223 k224 k225 k226 k227 k228 k229 k230 k231 k232 k233 k234 k235 k236 k237 k238 k239 k240 k241 k242 k243 k244 k245 k246 k247 k248 k249 k250 k251 k252 k253 k254 k255 k256 Time Bid] (concat (take (list [1 1 1 1 1 1]) 255) (list [1 1 1 2 2 2] [10:00:00.000 10:00:02.000 10:00:04.000 10:00:00.000 10:00:02.000 10:00:04.000] [99 100 101 1 2 3]))))
(set iv256 (map-left + [-2000 2000] (at L256 'Time)))
(at (window-join [k001 k002 k003 k004 k005 k006 k007 k008 k009 k010 k011 k012 k013 k014 k015 k016 k017 k018 k019 k020 k021 k022 k023 k024 k025 k026 k027 k028 k029 k030 k031 k032 k033 k034 k035 k036 k037 k038 k039 k040 k041 k042 k043 k044 k045 k046 k047 k048 k049 k050 k051 k052 k053 k054 k055 k056 k057 k058 k059 k060 k061 k062 k063 k064 k065 k066 k067 k068 k069 k070 k071 k072 k073 k074 k075 k076 k077 k078 k079 k080 k081 k082 k083 k084 k085 k086 k087 k088 k089 k090 k091 k092 k093 k094 k095 k096 k097 k098 k099 k100 k101 k102 k103 k104 k105 k106 k107 k108 k109 k110 k111 k112 k113 k114 k115 k116 k117 k118 k119 k120 k121 k122 k123 k124 k125 k126 k127 k128 k129 k130 k131 k132 k133 k134 k135 k136 k137 k138 k139 k140 k141 k142 k143 k144 k145 k146 k147 k148 k149 k150 k151 k152 k153 k154 k155 k156 k157 k158 k159 k160 k161 k162 k163 k164 k165 k166 k167 k168 k169 k170 k171 k172 k173 k174 k175 k176 k177 k178 k179 k180 k181 k182 k183 k184 k185 k186 k187 k188 k189 k190 k191 k192 k193 k194 k195 k196 k197 k198 k199 k200 k201 k202 k203 k204 k205 k206 k207 k208 k209 k210 k211 k212 k213 k214 k215 k216 k217 k218 k219 k220 k221 k222 k223 k224 k225 k226 k227 k228 k229 k230 k231 k232 k233 k234 k235 k236 k237 k238 k239 k240 k241 k242 k243 k244 k245 k246 k247 k248 k249 k250 k251 k252 k253 k254 k255 k256 Time] iv256 L256 R256 {minBid: (min Bid)}) 'minBid) -- [99 2]

;; ── 256 aggregates. meta len = 3 left + 256 = 259; last = (max Size).
(set tr256 (table [Sym Time Price] (list [x x x] [12:00:01 12:00:04 12:00:06] [89.17 70.5 80.54])))
(set qu256 (table [Sym Time Size] (list [x x x x x x x x x x] [12:00:00 12:00:01 12:00:02 12:00:03 12:00:04 12:00:05 12:00:06 12:00:07 12:00:08 12:00:09] [928 528 648 914 918 626 577 817 620 698])))
