;; ── F4 window: order: at 256 and 300 keys (src/ops/query.c n_order ->
;; ray_window_op, window.c ext->window.n_order_keys) — the one widened
;; count carrier the branch left without a 256/300 anti-truncation cell.
;; Single partition (part: [p], p constant 1 for all 100 rows) so ordering,
;; not partitioning, decides row rank. All order keys but the LAST are
;; constant (tied); the last key oNNN = 99 - (til 100), i.e. row i carries
;; oNNN_i = 99-i, so ascending order puts i=99 first (oNNN=0) and i=0 last
;; (oNNN=99) — a full reversal of source order, decided ENTIRELY by that
;; final key. v = til 100 (v_i = i), so within the one partition first(v)
;; = v at the sorted-first row = 99 and last(v) = v at the sorted-last row
;; = 0, both broadcast to every one of the 100 output rows: sum(f) =
;; 99*100 = 9900, sum(l) = 0. 100 rows clears the nrows<=64 insertion-sort
;; cutoff (window.c:802), exercising the radix/merge composite-sort path.
;;
;; Truncation check: a uint8_t cast on n_order collapses 256 -> 0 order keys
;; (order dropped entirely) and 300 -> 44 (only o000..o043 survive, all
;; constant/tied) — either way the discriminating final key is lost,
;; ordering degenerates to a no-op over the single tied partition, and
;; first(v)/last(v) stop being 99/0 (verified: reintroducing the cast at
;; query.c's ray_window_op call site flips these cells red). ──
(set to256 (table [p o000 o001 o002 o003 o004 o005 o006 o007 o008 o009 o010 o011 o012 o013 o014 o015 o016 o017 o018 o019 o020 o021 o022 o023 o024 o025 o026 o027 o028 o029 o030 o031 o032 o033 o034 o035 o036 o037 o038 o039 o040 o041 o042 o043 o044 o045 o046 o047 o048 o049 o050 o051 o052 o053 o054 o055 o056 o057 o058 o059 o060 o061 o062 o063 o064 o065 o066 o067 o068 o069 o070 o071 o072 o073 o074 o075 o076 o077 o078 o079 o080 o081 o082 o083 o084 o085 o086 o087 o088 o089 o090 o091 o092 o093 o094 o095 o096 o097 o098 o099 o100 o101 o102 o103 o104 o105 o106 o107 o108 o109 o110 o111 o112 o113 o114 o115 o116 o117 o118 o119 o120 o121 o122 o123 o124 o125 o126 o127 o128 o129 o130 o131 o132 o133 o134 o135 o136 o137 o138 o139 o140 o141 o142 o143 o144 o145 o146 o147 o148 o149 o150 o151 o152 o153 o154 o155 o156 o157 o158 o159 o160 o161 o162 o163 o164 o165 o166 o167 o168 o169 o170 o171 o172 o173 o174 o175 o176 o177 o178 o179 o180 o181 o182 o183 o184 o185 o186 o187 o188 o189 o190 o191 o192 o193 o194 o195 o196 o197 o198 o199 o200 o201 o202 o203 o204 o205 o206 o207 o208 o209 o210 o211 o212 o213 o214 o215 o216 o217 o218 o219 o220 o221 o222 o223 o224 o225 o226 o227 o228 o229 o230 o231 o232 o233 o234 o235 o236 o237 o238 o239 o240 o241 o242 o243 o244 o245 o246 o247 o248 o249 o250 o251 o252 o253 o254 o255 v] (concat (take (list (take [1] 100)) 256) (list (- 99 (til 100)) (til 100)))))
(set wo256 (window {from: to256 part: [p] order: [o000 o001 o002 o003 o004 o005 o006 o007 o008 o009 o010 o011 o012 o013 o014 o015 o016 o017 o018 o019 o020 o021 o022 o023 o024 o025 o026 o027 o028 o029 o030 o031 o032 o033 o034 o035 o036 o037 o038 o039 o040 o041 o042 o043 o044 o045 o046 o047 o048 o049 o050 o051 o052 o053 o054 o055 o056 o057 o058 o059 o060 o061 o062 o063 o064 o065 o066 o067 o068 o069 o070 o071 o072 o073 o074 o075 o076 o077 o078 o079 o080 o081 o082 o083 o084 o085 o086 o087 o088 o089 o090 o091 o092 o093 o094 o095 o096 o097 o098 o099 o100 o101 o102 o103 o104 o105 o106 o107 o108 o109 o110 o111 o112 o113 o114 o115 o116 o117 o118 o119 o120 o121 o122 o123 o124 o125 o126 o127 o128 o129 o130 o131 o132 o133 o134 o135 o136 o137 o138 o139 o140 o141 o142 o143 o144 o145 o146 o147 o148 o149 o150 o151 o152 o153 o154 o155 o156 o157 o158 o159 o160 o161 o162 o163 o164 o165 o166 o167 o168 o169 o170 o171 o172 o173 o174 o175 o176 o177 o178 o179 o180 o181 o182 o183 o184 o185 o186 o187 o188 o189 o190 o191 o192 o193 o194 o195 o196 o197 o198 o199 o200 o201 o202 o203 o204 o205 o206 o207 o208 o209 o210 o211 o212 o213 o214 o215 o216 o217 o218 o219 o220 o221 o222 o223 o224 o225 o226 o227 o228 o229 o230 o231 o232 o233 o234 o235 o236 o237 o238 o239 o240 o241 o242 o243 o244 o245 o246 o247 o248 o249 o250 o251 o252 o253 o254 o255] funcs: {f: (first v) l: (last v)}}))
