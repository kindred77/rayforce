;; ── F4 window: 256 funcs: entries over a single-partition 2-row fixture.
;; p01/p02 constant → one partition; v=[3.0 5.0]; each min broadcasts 3.0.
;; meta len = 3 source cols + 256 func cols = 259; every mnNNN = [3.0 3.0].
;; At a uint8-truncated 256→0 this collapsed to 3 cols with mn = raw v. ──
(set wp2 (table [p01 p02 v] (list [1 1] [1 1] [3.0 5.0])))
(set wpr256 (window {from: wp2 part: [p01 p02] funcs: {mn000: (min v) mn001: (min v) mn002: (min v) mn003: (min v) mn004: (min v) mn005: (min v) mn006: (min v) mn007: (min v) mn008: (min v) mn009: (min v) mn010: (min v) mn011: (min v) mn012: (min v) mn013: (min v) mn014: (min v) mn015: (min v) mn016: (min v) mn017: (min v) mn018: (min v) mn019: (min v) mn020: (min v) mn021: (min v) mn022: (min v) mn023: (min v) mn024: (min v) mn025: (min v) mn026: (min v) mn027: (min v) mn028: (min v) mn029: (min v) mn030: (min v) mn031: (min v) mn032: (min v) mn033: (min v) mn034: (min v) mn035: (min v) mn036: (min v) mn037: (min v) mn038: (min v) mn039: (min v) mn040: (min v) mn041: (min v) mn042: (min v) mn043: (min v) mn044: (min v) mn045: (min v) mn046: (min v) mn047: (min v) mn048: (min v) mn049: (min v) mn050: (min v) mn051: (min v) mn052: (min v) mn053: (min v) mn054: (min v) mn055: (min v) mn056: (min v) mn057: (min v) mn058: (min v) mn059: (min v) mn060: (min v) mn061: (min v) mn062: (min v) mn063: (min v) mn064: (min v) mn065: (min v) mn066: (min v) mn067: (min v) mn068: (min v) mn069: (min v) mn070: (min v) mn071: (min v) mn072: (min v) mn073: (min v) mn074: (min v) mn075: (min v) mn076: (min v) mn077: (min v) mn078: (min v) mn079: (min v) mn080: (min v) mn081: (min v) mn082: (min v) mn083: (min v) mn084: (min v) mn085: (min v) mn086: (min v) mn087: (min v) mn088: (min v) mn089: (min v) mn090: (min v) mn091: (min v) mn092: (min v) mn093: (min v) mn094: (min v) mn095: (min v) mn096: (min v) mn097: (min v) mn098: (min v) mn099: (min v) mn100: (min v) mn101: (min v) mn102: (min v) mn103: (min v) mn104: (min v) mn105: (min v) mn106: (min v) mn107: (min v) mn108: (min v) mn109: (min v) mn110: (min v) mn111: (min v) mn112: (min v) mn113: (min v) mn114: (min v) mn115: (min v) mn116: (min v) mn117: (min v) mn118: (min v) mn119: (min v) mn120: (min v) mn121: (min v) mn122: (min v) mn123: (min v) mn124: (min v) mn125: (min v) mn126: (min v) mn127: (min v) mn128: (min v) mn129: (mi