;; ── F8 group-key admission lift: a 17-key by-DICT now GROUPS correctly (cut-3
;; retires query.c's 'by-dict must have 1..16 keys' gate at the RAY_DICT by:
;; shape, and agg_group_keys' data[16] became a carve).  Bare-column-ref keys
;; are renames → the no-agg by-dict routes to the keys-only-distinct grouper.
;; Fixture: 17 int columns k01..k17, each [1 1 2] (rows 0,1 share tuple, row 2
;; differs) → exactly 2 distinct group tuples; each key column's first-of-group
;; value is [1 2].  (The 17-key raw sym-VECTOR by: form above takes the same
;; distinct grouper.) ──
(set t17d (table [k01 k02 k03 k04 k05 k06 k07 k08 k09 k10 k11 k12 k13 k14 k15 k16 k17] (list [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2] [1 1 2])))
(set r17d (select {from: t17d by: {k01: k01 k02: k02 k03: k03 k04: k04 k05: k05 k06: k06 k07: k07 k08: k08 k09: k09 k10: k10 k11: k11 k12: k12 k13: k13 k14: k14 k15: k15 k16: k16 k17: k17}}))
(count (at r17d 'k17)) -- 2
(at r17d 'k01) -- [1 2]
(at r17d 'k17) -- [1 2]
