(set rq256 (window-join [Sym Time] ivq256 tr256 qu256 {a000: (min Size) a001: (min Size) a002: (min Size) a003: (min Size) a004: (min Size) a005: (min Size) a006: (min Size) a007: (min Size) a008: (min Size) a009: (min Size) a010: (min Size) a011: (min Size) a012: (min Size) a013: (min Size) a014: (min Size) a015: (min Size) a016: (min Size) a017: (min Size) a018: (min Size) a019: (min Size) a020: (min Size) a021: (min Size) a022: (min Size) a023: (min Size) a024: (min Size) a025: (min Size) a026: (min Size) a027: (min Size) a028: (min Size) a029: (min Size) a030: (min Size) a031: (min Size) a032: (min Size) a033: (min Size) a034: (min Size) a035: (min Size) a036: (min Size) a037: (min Size) a038: (min Size) a039: (min Size) a040: (min Size) a041: (min Size) a042: (min Size) a043: (min Size) a044: (min Size) a045: (min Size) a046: (min Size) a047: (min Size) a048: (min Size) a049: (min Size) a050: (min Size) a051: (min Size) a052: (min Size) a053: (min Size) a054: (min Size) a055: (min Size) a056: (min Size) a057: (min Size) a058: (min Size) a059: (min Size) a060: (min Size) a061: (min Size) a062: (min Size) a063: (min Size) a064: (min Size) a065: (min Size) a066: (min Size) a067: (min Size) a068: (min Size) a069: (min Size) a070: (min Size) a071: (min Size) a072: (min Size) a073: (min Size) a074: (min Size) a075: (min Size) a076: (min Size) a077: (min Size) a078: (min Size) a079: (min Size) a080: (min Size) a081: (min Size) a082: (min Size) a083: (min Size) a084: (min Size) a085: (min Size) a086: (min Size) a087: (min Size) a088: (min Size) a089: (min Size) a090: (min Size) a091: (min Size) a092: (min Size) a093: (min Size) a094: (min Size) a095: (min Size) a096: (min Size) a097: (min Size) a098: (min Size) a099: (min Size) a100: (min Size) a101: (min Size) a102: (min Size) a103: (min Size) a104: (min Size) a105: (min Size) a106: (min Size) a107: (min Size) a108: (min Size) a109: (min Size) a110: (min Size) a111: (min Size) a112: (min Size) a113: (min Size) a114: (