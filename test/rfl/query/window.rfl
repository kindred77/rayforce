;; window form — language-surface correctness. Kernel itself is covered by
;; test/test_window.c; these cover parse + wiring + naming + row/col preservation.
;;   k : a a a b b b        (partition key)
;;   g : x x y x y y        (2nd partition key)
;;   v : 5 2 9 4 4 7        (value; note b/x has a single row=4, and the two
;;                           a-rows in group x are 5,2 → min 2)
(set T (table [k g v] (list ['a 'a 'a 'b 'b 'b] ['x 'x 'y 'x 'y 'y] [5 2 9 4 4 7])))

;; ── min over one partition key k: a-group min=2, b-group min=4 ──────────────
;; broadcast: rows k=a → 2 (x3), k=b → 4 (x3)
(at (window {from: T part: [k] funcs: {mn: (min v)}}) 'mn) -- [2 2 2 4 4 4]
;; input columns preserved + row order unchanged
(at (window {from: T part: [k] funcs: {mn: (min v)}}) 'v) -- [5 2 9 4 4 7]
(count (window {from: T part: [k] funcs: {mn: (min v)}})) -- 6

;; ── two partition keys (k,g): groups (a,x)=[5,2]→2, (a,y)=[9]→9,
;;    (b,x)=[4]→4, (b,y)=[4,7]→4 ; rows in order → [2 2 9 4 4 4] ───────────────
(at (window {from: T part: [k g] funcs: {mn: (min v)}}) 'mn) -- [2 2 9 4 4 4]

;; ── multiple funcs in one call: max and sum over k ──────────────────────────
;;   a-group v=[5,2,9] max=9 sum=16 ; b-group v=[4,4,7] max=7 sum=15
(at (window {from: T part: [k] funcs: {mx: (max v) sm: (sum v)}}) 'mx) -- [9 9 9 7 7 7]
(at (window {from: T part: [k] funcs: {mx: (max v) sm: (sum v)}}) 'sm) -- [16 16 16 15 15 15]

;; ── running frame → cumulative sum within partition k ordered by v ───────────
;;   partition a v=[5,2,9]: sorted asc → [2,5,9]; running sums 2,7,16 scattered
;;   back to original positions: row0(v=5)→7, row1(v=2)→2, row2(v=9)→16
;;   partition b v=[4,4,7]: sorted asc → [4,4,7]; running sums 4,8,15 in order
;;   full result in original row order: [7 2 16 4 8 15]
(at (window {from: T part: [k] order: [v] frame: 'running funcs: {cs: (sum v)}}) 'cs) -- [7 2 16 4 8 15]

;; ── fixed trailing frame → resets at each partition boundary ────────────
;; A positive integer frame is the number of rows including the current row.
(set M (table [k o v] (list ['a 'a 'b 'a 'b 'a] [1 2 1 3 2 4] [10 20 100 30 200 40])))
(set MW (window {from: M part: [k] order: [o] frame: 3 funcs: {ma: (avg v) ms: (sum v) mn: (min v) mx: (max v) n: (count v)}}))
(at MW 'ma) -- [10.0 15.0 100.0 20.0 150.0 30.0]
(at MW 'ms) -- [10 30 100 60 300 90]
(at MW 'mn) -- [10 10 100 10 100 20]
(at MW 'mx) -- [10 20 100 30 200 40]
(at MW 'n) -- [1 2 1 3 2 3]

;; ── F32 inputs promote numeric window results to F64 ──────────────────────
;; F32 used to fall through the I64 readers and silently broadcast zeros.
(.sys.exec "printf 'k,o,v\\na,1,1.5\\na,2,2.5\\nb,1,10.0\\na,3,3.5\\nb,2,20.0\\n' > /tmp/rfl_window_f32.csv")
(set F (.csv.read [SYMBOL I64 F32] "/tmp/rfl_window_f32.csv"))
(set FW (window {from: F part: [k] funcs: {sm: (sum v) av: (avg v) mn: (min v) mx: (max v)}}))
(type (at FW 'sm)) -- 'F64
(type (at FW 'av)) -- 'F64
(type (at FW 'mn)) -- 'F64
(type (at FW 'mx)) -- 'F64
(at FW 'sm) -- [7.5 7.5 30.0 7.5 30.0]
(at FW 'av) -- [2.5 2.5 15.0 2.5 15.0]
(at FW 'mn) -- [1.5 1.5 10.0 1.5 10.0]
(at FW 'mx) -- [3.5 3.5 20.0 3.5 20.0]

;; The same readers are used by running/trailing frames and value functions.
(set FT (window {from: F part: [k] order: [o] frame: 2 funcs: {sm: (sum v) av: (avg v) mn: (min v) mx: (max v)}}))
(at FT 'sm) -- [1.5 4.0 10.0 6.0 30.0]
(at FT 'av) -- [1.5 2.0 10.0 3.0 15.0]
(at FT 'mn) -- [1.5 1.5 10.0 2.5 10.0]
(at FT 'mx) -- [1.5 2.5 10.0 3.5 20.0]
(set FV (window {from: F part: [k] order: [o] funcs: {f: (first v) l: (last v)}}))
(type (at FV 'f)) -- 'F64
(at FV 'f) -- [1.5 1.5 10.0 1.5 10.0]
(at FV 'l) -- [3.5 3.5 20.0 3.5 20.0]
(.sys.exec "rm -f /tmp/rfl_window_f32.csv")

;; ── fby shape: rows equal to their group's min (keeps ties) ─────────────────
;; min over k: a→2 (only row v=2), b→4 (rows v=4,4 both) → 3 rows total
(count (select {from: (window {from: T part: [k] funcs: {mn: (min v)}}) where: (== v mn)})) -- 3

;; ── first/last with order: (Important 1 positive coverage) ──────────────────
;; part k, order v asc: a=[2,5,9]→first=2,last=9 ; b=[4,4,7]→first=4,last=7
(at (window {from: T part: [k] order: [v] funcs: {f: (first v) l: (last v)}}) 'f) -- [2 2 2 4 4 4]
(at (window {from: T part: [k] order: [v] funcs: {f: (first v) l: (last v)}}) 'l) -- [9 9 9 7 7 7]

;; ── errors ────────────────────────────────────────────────────────────────────
;; (a) unknown func
(window {from: T funcs: {x: (median v)}}) !- domain
;; (b) bad frame symbol
(window {from: T frame: 'bogus funcs: {mn: (min v)}}) !- domain
;; (b2) trailing row count must be positive
(window {from: T frame: 0 funcs: {mn: (min v)}}) !- range
;; (c) first without order:
(window {from: T part: [k] funcs: {f: (first v)}}) !- domain
;; (d) missing funcs:
(window {from: T part: [k]}) !- domain
