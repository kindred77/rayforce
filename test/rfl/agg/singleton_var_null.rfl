;; Characterization pin for the removal of the dead VAR/STDDEV "fixup" loop in
;; src/ops/group.c.  Singleton groups have undefined sample variance -> null.
;; The main radix-agg path writes the NULL_F64 sentinels directly; the removed
;; fixup loop (guarded by an always-true prep flag) NEVER executed.  If
;; this regresses, do NOT restore the fixup — fix the main agg path.
(set Tsng (table [g v] (list ['a 'b 'b 'c] [10.0 20.0 30.0 40.0])))

;; group a -> [10]      singleton -> sample var null
;; group b -> [20 30]   var = ((20-25)^2 + (30-25)^2) / (2-1) = 50.0
;; group c -> [40]      singleton -> sample var null
(at (select {sv: (var v) from: Tsng by: g}) 'sv) -- [0Nf 50.0 0Nf]

;; stddev shares the same fixup branch; sqrt(50) is irrational so recover the
;; variance by squaring stddev back (null stays null, defined group -> 50.0).
(set Rsd (select {sd: (stddev v) from: Tsng by: g}))
(at (* (at Rsd 'sd) (at Rsd 'sd)) 0) -- 0Nf
(at (* (at Rsd 'sd) (at Rsd 'sd)) 1) -- 50.0
(at (* (at Rsd 'sd) (at Rsd 'sd)) 2) -- 0Nf
