;; Invariants for `idesc` — indexes that would sort descending.

(idesc [30 10 20]) -- [0 2 1]

;; indices yield descending values
(set V (rand 200 10000))
(at V (idesc V)) -- (desc V)

;; is a permutation of (til n)
(asc (idesc V)) -- (til (count V))

;; ─── edge cases: empty / single / all-equal ──────────────────────────
;; empty vec
(idesc (as 'I64 (list))) -- (as 'I64 (list))
;; single-element
(idesc [42]) -- [0]
(idesc [3.14]) -- [0]
;; all-equal: stable sort returns input order (0..n-1)
(idesc [7 7 7 7]) -- [0 1 2 3]
(idesc (as 'F64 [3.14 3.14 3.14])) -- [0 1 2]
;; negatives
(idesc [-1 -3 -2]) -- [0 2 1]
