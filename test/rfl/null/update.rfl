;; Regression — (update {a: 0N from: t}) used to silently strip the null
;; bitmap during scalar-broadcast.  Column got 0s, not nulls.

(set t (table [a b] (list [1 2 3] [10 20 30])))
(set r (update {a: 0N from: t}))

;; Every cell in the updated column must be null.
(count (at r 'a)) -- (sum (map nil? (at r 'a)))

;; The other column must NOT have nulls (untouched).
0 -- (sum (map nil? (at r 'b)))

;; Same with WHERE clause (mask path also strips null without the fix).
(set t2 (table [a b] (list [1 2 3 4] [10 20 30 40])))
(set r2 (update {a: 0Nl where: (> b 15) from: t2}))
;; Rows 1, 2, 3 (b > 15) should now be null in column a; row 0 unchanged.
(at (at r2 'a) 0) -- 1
(nil? (at (at r2 'a) 1)) -- true
(nil? (at (at r2 'a) 2)) -- true
(nil? (at (at r2 'a) 3)) -- true

;; New-column branch — broadcasting 0N into a brand-new column also
;; used to drop the nulls.
(set r3 (update {c: 0N from: t}))
(nil? (at (at r3 'c) 0)) -- true
(nil? (at (at r3 'c) 1)) -- true
(nil? (at (at r3 'c) 2)) -- true

;; Type-promotion overlay — F64 expr written back to I64 col under WHERE.
;; The path memcpy's orig values, so the null state had to be carried over
;; manually for both unmasked rows (orig nulls) and masked rows (expr null).
(set t4 (table [a b] (list [1 2 0N 4] [10 20 30 40])))
(set r4 (update {a: (* a 1.5) where: (> b 15) from: t4}))
;; row 0: untouched, was 1 → 1
(at (at r4 'a) 0) -- 1
;; row 1: 2 * 1.5 = 3.0 → 3
(at (at r4 'a) 1) -- 3
;; row 2: 0N * 1.5 = null → must remain null after overlay+cast
(nil? (at (at r4 'a) 2)) -- true
;; row 3: 4 * 1.5 = 6.0 → 6
(at (at r4 'a) 3) -- 6

;; I64→F64 promotion path (no WHERE) preserves nulls in the source vec.
(set t5 (table [a b] (list [1.0 2.0 0N 4.0] [10 20 30 40])))
(set r5 (update {a: (+ a 1) from: t5}))
(nil? (at (at r5 'a) 2)) -- true
