;; Invariants for `<=`.

;; reflexive: (<= a a) is true
(set A (- (rand 256 200000) 100000))
(count A) -- (sum (<= A A))

;; (<= a b) == (or (< a b) (== a b))
(set B (- (rand 256 200000) 100000))
(count A) -- (sum (== (<= A B) (or (< A B) (== A B))))

;; concrete
(<= 1 2) -- true
(<= 2 1) -- false
(<= 3 3) -- true

;; cross-types
(<= 5h 5h)   -- true
(<= 3i 5i)   -- true
(<= 2.5 2.5) -- true

;; STR / DATE
(<= "a" "b") -- true
(<= "x" "x") -- true
(<= 2024.01.15 2024.06.01) -- true

;; vec
(<= [1 5 5] [2 2 5]) -- [true false true]

;; ──────────────────────────────────────────────────────────────────
;; SYM ordering: reflexive, lexicographic.
;; ──────────────────────────────────────────────────────────────────

(<= 'a 'a) -- true
(<= 'a 'b) -- true
(<= 'b 'a) -- false
(<= ['a 'b 'c] 'b) -- [true true false]

;; type errors — cross-type compare not numeric/temporal/sym/str
(<= 'foo 1) !- type
(<= 1 'foo) !- type

;; ──────────────────────────────────────────────────────────────────
;; GUID lex <= (memcmp16 path)
;; ──────────────────────────────────────────────────────────────────
(set Gs (take (guid 2) 2))
(<= (at Gs 0) (at Gs 0)) -- true

;; Cross-temporal <=
(<= (as 'DATE 7305) (as 'DATE 7306)) -- true
(<= (as 'DATE 7305) (as 'DATE 7305)) -- true
(<= (as 'TIME 1000) (as 'TIME 2000)) -- true
(<= (as 'TIMESTAMP 100) (as 'TIMESTAMP 200)) -- true

;; Mixed-width numeric <=
(<= (as 'I16 100) (as 'I32 200)) -- true
(<= (as 'F64 100.0) (as 'I64 200)) -- true
(<= (as 'U8 5) (as 'I32 100)) -- true
