;; Invariants for `!=`.

;; irreflexive: (!= a a) is false
(set A (- (rand 256 200000) 100000))
(count A) -- (sum (not (!= A A)))

;; dual of ==:  (!= a b) == (not (== a b))
(set B (- (rand 256 200000) 100000))
(count A) -- (sum (== (!= A B) (not (== A B))))

;; symmetric
(count A) -- (sum (== (!= A B) (!= B A)))

;; concrete
(!= 1 2)  -- true
(!= 3 3)  -- false
(!= -1 1) -- true

;; cross-type
(!= "a" "a") -- false
(!= "a" "b") -- true
(!= 'a 'a) -- false
(!= 'a 'b) -- true

;; cross-width
(!= 5h 5)  -- false
(!= 5h 6)  -- true
(!= 5 5.0) -- false

;; vec
(!= [1 2 3] [1 5 3]) -- [false true false]

;; complementary to == per-element
(!= [1 2 3] [1 2 3]) -- [false false false]
