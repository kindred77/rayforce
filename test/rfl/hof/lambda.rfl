;; Ported from test_lang_rf.inc::test_rf_lambda.

;; ========== BASIC LAMBDA ==========
((fn [x] (+ x 1)) 5) -- 6
((fn [x y] (+ x y)) 3 4) -- 7
((fn [] 42)) -- 42
;; ========== LAMBDA WITH MULTIPLE ARGS ==========
((fn [a b c] (+ a (+ b c))) 1 2 3) -- 6
((fn [x y z] (* x (* y z))) 2 3 4) -- 24
;; ========== STORED LAMBDA ==========
(set f (fn [x] (* x x))) (f 5) -- 25
(set add (fn [a b] (+ a b))) (add 10 20) -- 30
;; ========== LAMBDA WITH MAP ==========
(map (fn [x] (* x 2)) [1 2 3 4 5]) -- [2 4 6 8 10]
(map (fn [x] (+ x 10)) [0 1 2]) -- [10 11 12]
;; ========== LAMBDA WITH FILTER/WHERE ==========
(filter [1 2 3 4 5 6] (map (fn [x] (> x 3)) [1 2 3 4 5 6])) -- [4 5 6]
;; ========== LAMBDA WITH CONDITIONALS ==========
((fn [x] (if (> x 0) 'pos 'neg)) 5) -- 'pos
((fn [x] (if (> x 0) 'pos 'neg)) -5) -- 'neg
;; ========== RECURSIVE-STYLE (SELF) ==========
(set factorial (fn [n] (if (<= n 1) 1 (* n (factorial (- n 1)))))) (factorial 5) -- 120
