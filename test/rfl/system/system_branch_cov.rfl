;; system_branch_cov.rfl — branch coverage for src/ops/system.c (part 1).
;;
;; Covers: ser/de, splayed set/get, parted get, os.size, os.list,
;; guid, eval, parse, meta, system, getenv, setenv, gc.
;;
;; Conventions:
;;   LHS -- RHS   assert equality
;;   EXPR !- TAG  assert error containing TAG
;;
;; All filesystem fixtures use /tmp/rfl_sys_bc_* prefix.

;; ────────────── pre-flight cleanup ──────────────
(.sys.exec "rm -rf /tmp/rfl_sys_bc_*")

;; ══════════════════════════════════════════════════════════════════════
;; ray_ser_fn / ray_de_fn  (lines 47-54)
;; ══════════════════════════════════════════════════════════════════════
(de (ser 0))   -- 0
(de (ser 0N))  -- 0N
(de (ser ""))  -- ""
(count (de (ser (take [1] 0)))) -- 0
(de (ser (list 1 "a" 'b)))  -- (list 1 "a" 'b)

;; ══════════════════════════════════════════════════════════════════════
;; ray_set_splayed_fn  (lines 78-99) — arity / type guards
;; ══════════════════════════════════════════════════════════════════════
(.db.splayed.set "/tmp/rfl_sys_bc_a") !- domain
(.db.splayed.set "/tmp/rfl_sys_bc_a" (table [x] (list [1])) "/tmp/foo" "extra") !- domain
(.db.splayed.set 42 (table [x] (list [1]))) !- type
(.db.splayed.set "/tmp/rfl_sys_bc_a/" 42) !- type
(.db.splayed.set "/tmp/rfl_sys_bc_a/" null) !- type

;; 3-arg form: explicit sym_path
(.db.splayed.set "/tmp/rfl_sys_bc_sym3/" (table [s v] (list ['A 'B] [1 2])) "/tmp/rfl_sys_bc_sym3/sym")
(count (.db.splayed.get "/tmp/rfl_sys_bc_sym3/")) -- 2
(.db.splayed.get "/tmp/rfl_sys_bc_sym3/") -- (table [s v] (list ['A 'B] [1 2]))
;; 3-arg form: non-string third arg falls back to default sym path
(.db.splayed.set "/tmp/rfl_sys_bc_sym3b/" (table [s v] (list ['A 'B] [1 2])) 42)
(count (.db.splayed.get "/tmp/rfl_sys_bc_sym3b/")) -- 2
(.db.splayed.get "/tmp/rfl_sys_bc_sym3b/") -- (table [s v] (list ['A 'B] [1 2]))

;; ══════════════════════════════════════════════════════════════════════
;; ray_get_splayed_fn  (lines 102-116) — arity / type guards
;; ══════════════════════════════════════════════════════════════════════
(.db.splayed.get) !- domain
(.db.splayed.get "/tmp/rfl_sys_bc_sym3/" "/tmp/rfl_sys_bc_sym3/sym" "extra") !- domain
(.db.splayed.get 42) !- type
(count (.db.splayed.get "/tmp/rfl_sys_bc_sym3/" "/tmp/rfl_sys_bc_sym3/sym")) -- 2
(.db.splayed.get "/tmp/rfl_sys_bc_sym3/" "/tmp/rfl_sys_bc_sym3/sym") -- (table [s v] (list ['A 'B] [1 2]))
(count (.db.splayed.get "/tmp/rfl_sys_bc_sym3/" 42)) -- 2
(.db.splayed.get "/tmp/rfl_sys_bc_sym3/" 42) -- (table [s v] (list ['A 'B] [1 2]))

;; ══════════════════════════════════════════════════════════════════════
;; ray_get_parted_fn  (lines 119-137) — arity / type / name guards
;; ══════════════════════════════════════════════════════════════════════
(.db.parted.get "/tmp/foo") !- domain
(.db.parted.get "/tmp/foo" 't "extra") !- domain
(.db.parted.get 42 't) !- type
(.db.parted.get "/tmp/rfl_sys_bc_sym3/" "t") !- type
(.db.parted.get "/tmp/rfl_sys_bc_sym3/" null) !- type

;; ══════════════════════════════════════════════════════════════════════
;; ray_os_size_fn  (lines 338-349)
;; ══════════════════════════════════════════════════════════════════════
(.os.size [1 2 3]) !- type
(.os.size 'foo) !- type
(.os.size "/tmp/rfl_sys_bc_nofile.txt") !- io
(.os.size "/tmp") !- io
(.sys.exec "touch /tmp/rfl_sys_bc_empty.txt")
(.os.size "/tmp/rfl_sys_bc_empty.txt") -- 0
(.sys.exec "printf 'abcdef' > /tmp/rfl_sys_bc_6bytes.txt")
(.os.size "/tmp/rfl_sys_bc_6bytes.txt") -- 6

;; ══════════════════════════════════════════════════════════════════════
;; ray_os_list_fn  (lines 365-425)
;; ══════════════════════════════════════════════════════════════════════
(.os.list [1 2]) !- type
(.os.list 42) !- type
(.os.list "/tmp/rfl_sys_bc_nosuchdir/") !- io
(.os.list "/tmp/rfl_sys_bc_empty.txt") !- io
;; Directory with a single file
(.sys.exec "mkdir -p /tmp/rfl_sys_bc_onefile/ && touch /tmp/rfl_sys_bc_onefile/x")
(count (.os.list "/tmp/rfl_sys_bc_onefile/")) -- 1
(.os.list "/tmp/rfl_sys_bc_onefile/") -- [x]
;; dot-prefixed entries (not . or ..) ARE listed
(.sys.exec "touch /tmp/rfl_sys_bc_onefile/.hidden")
(count (.os.list "/tmp/rfl_sys_bc_onefile/")) -- 2
;; sorted symbol vector: ".hidden" sorts before "x"
(.os.list "/tmp/rfl_sys_bc_onefile/") -- ['.hidden 'x]
;; > 16 entries triggers realloc growth path
(.sys.exec "mkdir -p /tmp/rfl_sys_bc_bigdir && cd /tmp/rfl_sys_bc_bigdir && for i in $(seq 1 20); do touch f_$(printf '%02d' $i); done")
(count (.os.list "/tmp/rfl_sys_bc_bigdir/")) -- 20
;; entries are sorted: first is f_01, last is f_20
(first (.os.list "/tmp/rfl_sys_bc_bigdir/")) -- 'f_01
(last (.os.list "/tmp/rfl_sys_bc_bigdir/")) -- 'f_20
;; Empty directory — previously triggered qsort(NULL, 0, ...) UB.
(.sys.exec "mkdir -p /tmp/rfl_sys_bc_emptydir")
(count (.os.list "/tmp/rfl_sys_bc_emptydir/")) -- 0
(.sys.exec "rm -rf /tmp/rfl_sys_bc_emptydir")

;; ══════════════════════════════════════════════════════════════════════
;; ray_guid_fn  (lines 456-475)
;; ══════════════════════════════════════════════════════════════════════
(guid "x") !- type
(guid 'foo) !- type
(guid -1) !- domain
(count (guid 0)) -- 0
(type (guid 0)) -- 'GUID
(count (guid 1)) -- 1
(diverse (guid 10)) -- true
(count (guid 3i)) -- 3

;; ══════════════════════════════════════════════════════════════════════
;; ray_eval_builtin_fn  (line 482-484)
;; ══════════════════════════════════════════════════════════════════════
(eval (parse "(+ 1 2)")) -- 3
(eval (parse "(* 3 4)")) -- 12
(eval 42) -- 42
(eval "hello") -- "hello"

;; ══════════════════════════════════════════════════════════════════════
;; ray_parse_builtin_fn  (lines 487-493)
;; ══════════════════════════════════════════════════════════════════════
(parse 42) !- type
(parse 'foo) !- type
(type (parse "(+ 1 2)")) -- 'LIST
;; parse yields the AST as a list: the + symbol applied to 1 and 2
(parse "(+ 1 2)") -- (list '+ 1 2)
(count (parse "(+ 1 2)")) -- 3
(at (parse "(+ 1 2)") 0) -- '+
(at (parse "(+ 1 2)") 1) -- 1
(at (parse "(+ 1 2)") 2) -- 2

;; ══════════════════════════════════════════════════════════════════════
;; ray_meta_fn  (lines 499-535)
;; ══════════════════════════════════════════════════════════════════════
(count (meta 42)) -- 1
(at (meta 42) 'type) -- 'i64
(count (meta "hello")) -- 1
(at (meta "hello") 'type) -- 'str
(count (meta [1 2 3])) -- 2
(at (meta [1 2 3]) 'type) -- 'I64
(at (meta [1 2 3]) 'len) -- 3
(at (meta (dict ['a 'b] [1 2])) 'len) -- 2
(at (meta (table [x y] (list [1 2] [3 4]))) 'len) -- 2
(at (meta (list 1 2 3 4 5)) 'len) -- 5
(at (meta true) 'type) -- 'b8
(at (meta 2024.01.15) 'type) -- 'date
(at (meta 0x01) 'type) -- 'u8
(at (meta 1h) 'type) -- 'i16
(at (meta 1i) 'type) -- 'i32
(at (meta 1.0) 'type) -- 'f64
;; (meta null) errors with "type" since !x is true for null
(meta null) !- type

;; ══════════════════════════════════════════════════════════════════════
;; ray_system_fn  (lines 542-548) — type guard
;; ══════════════════════════════════════════════════════════════════════
(.sys.exec 42) !- type
(.sys.exec 'foo) !- type
(.sys.exec "echo hello >/dev/null") -- 0
(== 0 (.sys.exec "false")) -- false

;; ══════════════════════════════════════════════════════════════════════
;; ray_getenv_fn / ray_setenv_fn  (lines 551-575)
;; ══════════════════════════════════════════════════════════════════════
(.os.getenv 42) !- type
(.os.getenv 'foo) !- type
(.os.getenv "RFL_NO_SUCH_ENV_VAR_12345") -- ""
(.os.setenv "RFL_SYS_BC_T" "value1")
(.os.getenv "RFL_SYS_BC_T") -- "value1"
(.os.setenv 42 "val") !- type
(.os.setenv "name" 42) !- type
(.os.setenv 42 42) !- type
(.os.setenv "RFL_SYS_BC_T" "second")
(.os.getenv "RFL_SYS_BC_T") -- "second"

;; ══════════════════════════════════════════════════════════════════════
;; ray_gc_fn  (line 539)
;; ══════════════════════════════════════════════════════════════════════
(.sys.gc) -- 0
(.sys.gc 0) -- 0
(.sys.gc "x") -- 0

;; ────────────── teardown ──────────────
(.sys.exec "rm -rf /tmp/rfl_sys_bc_*")
