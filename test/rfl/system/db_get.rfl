;; Multi-table roots through the explicit .db trio — the surface left
;; after the .db.*.mount removal: every table is opened by name with
;; .db.splayed.get / .db.parted.get; nothing is discovered or bound
;; implicitly.  Tests below cover correctness (round-trip values) for
;; several splayed tables under one root, a multi-table parted root,
;; and the error paths for wrong-format / missing roots.

;; .db.splayed.set sweeps stale files and commits .d last, so re-setting
;; over a previous run is safe; the wipe below just isolates fixtures.
(.sys.exec "rm -rf /tmp/rfl_get_splayed /tmp/rfl_get_parted")

;; ────────────── several splayed tables under one root ──────────────
(set Trades  (table [s p] (list ['AAPL 'GOOG] [100.0 200.0])))
(set Quotes  (table [s b a] (list ['AAPL 'GOOG] [99.0 199.0] [101.0 201.0])))
(set Returns (table [s r] (list ['AAPL 'GOOG] [0.01 -0.02])))

;; All three tables share ONE root symfile (the client layout): a
;; multi-table root keeps a single vocabulary so cross-table SYM ops
;; (joins, comparisons) stay on the same-domain fast path instead of
;; re-encoding positions between per-table domains.
(.db.splayed.set "/tmp/rfl_get_splayed/Trades"  Trades  "/tmp/rfl_get_splayed/.sym")
(.db.splayed.set "/tmp/rfl_get_splayed/Quotes"  Quotes  "/tmp/rfl_get_splayed/.sym")
(.db.splayed.set "/tmp/rfl_get_splayed/Returns" Returns "/tmp/rfl_get_splayed/.sym")

;; exactly one symfile — at the root, none per table dir
(.sys.exec "test -f /tmp/rfl_get_splayed/.sym")        -- 0
(.sys.exec "test ! -f /tmp/rfl_get_splayed/Trades/.sym") -- 0

;; Wipe the originals so the post-get bindings provably came from disk.
(set Trades  0)
(set Quotes  0)
(set Returns 0)

(set Trades  (.db.splayed.get "/tmp/rfl_get_splayed/Trades/"  "/tmp/rfl_get_splayed/.sym"))
(set Quotes  (.db.splayed.get "/tmp/rfl_get_splayed/Quotes/"  "/tmp/rfl_get_splayed/.sym"))
(set Returns (.db.splayed.get "/tmp/rfl_get_splayed/Returns/" "/tmp/rfl_get_splayed/.sym"))

(type Trades)  -- 'TABLE
(type Quotes)  -- 'TABLE
(type Returns) -- 'TABLE
(count Trades)  -- 2
(count Quotes)  -- 2
(count Returns) -- 2
;; Cardinality alone can't tell a correctly-loaded table from a stub of
;; the same row count: pin the round-tripped COLUMN VALUES too.
(sum (at Trades 'p))  -- 300.0       ;; [100.0 200.0]
(sum (at Quotes 'b))  -- 298.0       ;; [99.0 199.0]
(sum (at Quotes 'a))  -- 302.0       ;; [101.0 201.0]
(sum (at Returns 'r)) -- -0.01       ;; [0.01 -0.02]
;; sym column survives the round trip cell-for-cell.
(at (at Trades 's) 0) -- 'AAPL
(at (at Trades 's) 1) -- 'GOOG

;; ────────────── multi-table parted root: 2 partitions × 2 tables ──────────────
(set T-A0 (table [s v] (list ['a 'b] [1 2])))
(set T-A1 (table [s v] (list ['c 'd] [3 4])))
(set T-B0 (table [s v] (list ['e 'f] [5 6])))
(set T-B1 (table [s v] (list ['g 'h] [7 8])))

(.db.splayed.set "/tmp/rfl_get_parted/2024.01.01/A/" T-A0)
(.db.splayed.set "/tmp/rfl_get_parted/2024.01.02/A/" T-A1)
(.db.splayed.set "/tmp/rfl_get_parted/2024.01.01/B/" T-B0)
(.db.splayed.set "/tmp/rfl_get_parted/2024.01.02/B/" T-B1)

;; Each table of the root is opened explicitly by name.
(set A (.db.parted.get "/tmp/rfl_get_parted/" 'A))
(set B (.db.parted.get "/tmp/rfl_get_parted/" 'B))

;; Each is the concatenated 2-partition view.
(count A) -- 4   ;; 2 partitions × 2 rows each
(count B) -- 4
;; Cardinality says "4 rows" but not WHICH rows: verify the concatenated
;; 'v column carries both partitions' values.  A = [1 2] (01.01) + [3 4]
;; (01.02); B = [5 6] (01.01) + [7 8] (01.02).
;; BUG: a raw whole-column read `(at A 'v)` returns the parted column
;; UN-MATERIALISED (renders as <?>), so value-check via aggregates (which
;; have a parted code path).
(sum (at A 'v)) -- 10
(min (at A 'v)) -- 1
(max (at A 'v)) -- 4
(sum (at B 'v)) -- 26
(min (at B 'v)) -- 5
(max (at B 'v)) -- 8

;; ────────────── .db.parted.tables: discover the table names ──────────────
;; Returns the splayed-table subdirectories of the first partition as a
;; sorted SYM vector — usable directly with .db.parted.get, no binding.
(.db.parted.tables "/tmp/rfl_get_parted/")        -- ['A 'B]
(count (.db.parted.tables "/tmp/rfl_get_parted/")) -- 2
;; a discovered name feeds straight back into .db.parted.get.
(count (.db.parted.get "/tmp/rfl_get_parted/" (at (.db.parted.tables "/tmp/rfl_get_parted/") 0))) -- 4
;; not a parted root (splayed root has no partition dirs) -> io error.
(.db.parted.tables "/tmp/rfl_get_splayed/")        !- io
(.db.parted.tables "/tmp/rfl_get_does_not_exist/") !- io

;; ────────────── error path: not a parted root ──────────────
;; The splayed root from the first test has no partition directories,
;; so .db.parted.get on it must fail rather than returning an empty
;; table (which would silently mask the wrong-format mistake).
(.db.parted.get "/tmp/rfl_get_splayed/" 'Trades) !- io

;; ────────────── error path: nonexistent directory ──────────────
(.db.splayed.get "/tmp/rfl_get_does_not_exist/")    !- io
(.db.parted.get  "/tmp/rfl_get_does_not_exist/" 't) !- io

;; ────────────── overwrite heal: narrower re-set sweeps stale columns ──────────────
;; Re-set against the same shared symfile: 'ZZZ appends to the root
;; vocabulary (append-only), the stale p column is swept.
(.db.splayed.set "/tmp/rfl_get_splayed/Trades" (table [s] (list ['ZZZ])) "/tmp/rfl_get_splayed/.sym")
(set Trades2 (.db.splayed.get "/tmp/rfl_get_splayed/Trades/" "/tmp/rfl_get_splayed/.sym"))
(count (key Trades2)) -- 1
(at (at Trades2 's) 0) -- 'ZZZ

;; ────────────── cross-partition schema validation ──────────────
;; Names, order, and types must match the first partition; the error
;; names the divergent partition + column (code "corrupt").
(.sys.exec "rm -rf /tmp/rfl_get_badschema")
(.db.splayed.set "/tmp/rfl_get_badschema/2024.01.01/t/" (table [a b] (list [1 2] [3 4])))
(.db.splayed.set "/tmp/rfl_get_badschema/2024.01.02/t/" (table [a c] (list [5 6] [7 8])))
(.db.parted.get "/tmp/rfl_get_badschema/" 't) !- corrupt
;; Type divergence at same name is rejected too.
(.db.splayed.set "/tmp/rfl_get_badschema/2024.01.02/t/" (table [a b] (list [5 6] [7.0 8.0])))
(.db.parted.get "/tmp/rfl_get_badschema/" 't) !- corrupt
(.sys.exec "rm -rf /tmp/rfl_get_badschema")

;; ────────────── cleanup ──────────────
(.sys.exec "rm -rf /tmp/rfl_get_splayed /tmp/rfl_get_parted") -- 0
