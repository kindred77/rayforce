;; .fs.size and .fs.list — filesystem metadata primitives, issue #36.
;;
;; Two functions on purpose: every other predicate (exists, is-file,
;; is-dir) is reachable via `try` against these or via the shell
;; fallback in .sys.cmd, so we don't bloat the surface.  Both errors
;; are flagged "io" so user code can dispatch on category without
;; parsing the message.

;; ────────────── pre-flight: pristine fixture under /tmp ──────────────
;; Use the test process's exec primitive to set up.  Real paths are
;; unstable (CI uses different tmp roots) but /tmp is universal on
;; the platforms rayforce targets, and these fixtures are tiny.
(.sys.exec "rm -rf /tmp/rf_os_fs_test")
(.sys.exec "mkdir -p /tmp/rf_os_fs_test/sub")
(.sys.exec "printf 'hello world\\n' > /tmp/rf_os_fs_test/file.txt")
(.sys.exec "touch /tmp/rf_os_fs_test/sub/a /tmp/rf_os_fs_test/sub/c /tmp/rf_os_fs_test/sub/b")

;; ────────────── .fs.size: regular file ──────────────
(.fs.size "/tmp/rf_os_fs_test/file.txt") -- 12   ;; "hello world\n"

;; ────────────── .fs.size: directory and missing both error ──────────────
;; Same error category ("io") so try/catch can treat them uniformly
;; — the error message distinguishes when a human is looking.
(.fs.size "/tmp/rf_os_fs_test")           !- io
(.fs.size "/tmp/rf_os_fs_test/nope.txt")  !- io

;; ────────────── .fs.list: directory entries, sorted ──────────────
;; readdir order is filesystem-defined; we sort so tests are stable
;; and `..` / `.` are filtered.  The fixture above writes a c b in
;; non-sorted order to prove the sort actually runs.
(.fs.list "/tmp/rf_os_fs_test/sub")  -- ['a 'b 'c]
(.fs.list "/tmp/rf_os_fs_test")      -- ['file.txt 'sub]

;; ────────────── .fs.list: file and missing both error ──────────────
(.fs.list "/tmp/rf_os_fs_test/file.txt") !- io
(.fs.list "/tmp/rf_os_fs_test/nope")     !- io

;; ────────────── existence-check via try ──────────────
;; The motivating idiom: probe size, swallow the error.  Truthy →
;; the path is a regular file with a knowable size.
(try (>= (.fs.size "/tmp/rf_os_fs_test/file.txt") 0) (fn [_] false))  -- true
(try (>= (.fs.size "/tmp/rf_os_fs_test/nope")     0) (fn [_] false))  -- false

;; ────────────── is-dir discriminator via try ──────────────
;; .fs.list errors on non-directories, so a successful list (even
;; empty) is the directory marker.
(try (do (.fs.list "/tmp/rf_os_fs_test/sub") true) (fn [_] false))  -- true
(try (do (.fs.list "/tmp/rf_os_fs_test/file.txt") true) (fn [_] false))  -- false

;; ────────────── argument validation ──────────────
(.fs.size 5)      !- type
(.fs.list 'foo)   !- type

;; ────────────── teardown ──────────────
(.sys.exec "rm -rf /tmp/rf_os_fs_test")
