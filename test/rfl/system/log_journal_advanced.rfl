;; Journal feature — invariants the basic test (log_journal.rfl) does
;; not cover.  Each phase uses a distinct base + port so a phase
;; failing mid-run doesn't pollute the next one's state.
;;
;; Phase A: -L sync mode survives kill -9 (durability promise of -L)
;; Phase B: user override of a builtin survives snapshot/restart
;;          (regression trap for the env user-flag invariant)
;; Phase C: per-entry eval error in log warns-and-continues, doesn't
;;          abort replay (commit message documents this; basic test
;;          only exercises framing badtail)
;; Phase D: .log.write manual escape hatch round-trips via replay

;; ════════════════════════════════════════════════════════════════════
;; Phase A — -L durability under kill -9
;; ════════════════════════════════════════════════════════════════════
;; The whole point of -L is "fsync per write so a hard kill mid-handler
;; doesn't lose the message".  -l (async) might survive SIGTERM thanks
;; to OS buffers but -L is the contract; if it stopped fsyncing the
;; current test suite would not notice.  Use kill -9 (no clean
;; shutdown, no fclose, no fflush) so only the on-disk bytes count.

(.sys.exec "pkill -KILL -f '[r]ayforce -L /tmp/rftest_jdura' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jdura*")
(.sys.exec "./rayforce -L /tmp/rftest_jdura -p 19991 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19991) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hA (.ipc.open "127.0.0.1:19991"))
(.ipc.send hA "(set durable_a 7)") -- 7
(.ipc.send hA "(set durable_b \"survived\")") -- "survived"
(.ipc.close hA)

;; SIGKILL — no atexit, no fclose, no fflush.  Only the bytes the
;; SYNC fsync put on disk count.
(.sys.exec "pkill -KILL -f '[r]ayforce -L /tmp/rftest_jdura -p 19991' 2>/dev/null; true")
(.sys.exec "for i in $(seq 30); do pgrep -f '[r]ayforce -L /tmp/rftest_jdura -p 19991' >/dev/null || exit 0; sleep 0.1; done; exit 1") -- 0

;; Restart with -L on the same base.  Both bindings must come back.
(.sys.exec "./rayforce -L /tmp/rftest_jdura -p 19991 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19991) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hA2 (.ipc.open "127.0.0.1:19991"))
(.ipc.send hA2 "durable_a") -- 7
(.ipc.send hA2 "durable_b") -- "survived"
(.ipc.close hA2)
(.sys.exec "pkill -KILL -f '[r]ayforce -L /tmp/rftest_jdura' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jdura*")

;; ════════════════════════════════════════════════════════════════════
;; Phase B — user override of a builtin survives snapshot
;; ════════════════════════════════════════════════════════════════════
;; (set + 42) flips the slot at `+` to user=1.  The slot SHOULD be
;; included in the next .log.snapshot so the override survives a
;; restart loaded from .qdb.  If the user-flag upgrade in
;; env_bind_global_impl regresses, this test catches it; the basic
;; log_journal test only writes fresh user globals (a/b/c/d) and
;; would miss the regression silently.

(.sys.exec "pkill -KILL -f '[r]ayforce -l /tmp/rftest_jovr' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jovr*")
(.sys.exec "./rayforce -l /tmp/rftest_jovr -p 19992 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19992) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hB (.ipc.open "127.0.0.1:19992"))
;; Override the `+` builtin with a sentinel integer, then snapshot.
;; The snapshot's .qdb must contain `+` -> 42 so phase-B-restart can
;; load it from .qdb (not from log replay, which is also rolled).
(.ipc.send hB "(set + 42)") -- 42
(.ipc.send hB "+") -- 42
(.ipc.send hB "(.log.snapshot)")
(.ipc.close hB)
(.sys.exec "pkill -TERM -f '[r]ayforce -l /tmp/rftest_jovr -p 19992' 2>/dev/null; true")
(.sys.exec "for i in $(seq 30); do pgrep -f '[r]ayforce -l /tmp/rftest_jovr -p 19992' >/dev/null || exit 0; sleep 0.1; done; exit 1") -- 0

(.sys.exec "./rayforce -l /tmp/rftest_jovr -p 19992 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19992) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hB2 (.ipc.open "127.0.0.1:19992"))
;; The override must have survived the .qdb roundtrip.
(.ipc.send hB2 "+") -- 42
(.ipc.close hB2)
(.sys.exec "pkill -KILL -f '[r]ayforce -l /tmp/rftest_jovr' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jovr*")

;; ════════════════════════════════════════════════════════════════════
;; Phase C — per-entry eval error during replay warns-and-continues
;; ════════════════════════════════════════════════════════════════════
;; Send 3 mutations.  Middle one references an undefined symbol —
;; will error on REPLAY (it errored on original eval too, but log
;; was written before eval).  Restart must still apply the first and
;; third.  Without the documented hybrid policy the whole replay
;; would abort and surviving server would not have c1 / c3 set.

(.sys.exec "pkill -KILL -f '[r]ayforce -l /tmp/rftest_jerr' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jerr*")
(.sys.exec "./rayforce -l /tmp/rftest_jerr -p 19993 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19993) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hC (.ipc.open "127.0.0.1:19993"))
(.ipc.send hC "(set c1 100)") -- 100
;; This one errors on the server (undefined `not_a_thing`) — the
;; .ipc.send returns an error response, but the inbound message was
;; journaled before eval.
(try (.ipc.send hC "(set c2 not_a_thing)") (fn [e] 0))
(.ipc.send hC "(set c3 300)") -- 300
(.ipc.close hC)
(.sys.exec "pkill -TERM -f '[r]ayforce -l /tmp/rftest_jerr -p 19993' 2>/dev/null; true")
(.sys.exec "for i in $(seq 30); do pgrep -f '[r]ayforce -l /tmp/rftest_jerr -p 19993' >/dev/null || exit 0; sleep 0.1; done; exit 1") -- 0

(.sys.exec "./rayforce -l /tmp/rftest_jerr -p 19993 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19993) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hC2 (.ipc.open "127.0.0.1:19993"))
(.ipc.send hC2 "c1") -- 100
;; c2 is expected to be undefined (the bad replay entry was warn-
;; skipped, not applied).  Use try to catch the undefined-name error.
(try (.ipc.send hC2 "c2") (fn [e] "missing")) -- "missing"
(.ipc.send hC2 "c3") -- 300
(.ipc.close hC2)
(.sys.exec "pkill -KILL -f '[r]ayforce -l /tmp/rftest_jerr' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jerr*")

;; ════════════════════════════════════════════════════════════════════
;; Phase D — .log.write manual entry round-trips via replay
;; ════════════════════════════════════════════════════════════════════
;; The escape hatch lets a Rayfall handler journal an arbitrary
;; expression out-of-band.  Currently zero coverage — a regression
;; that broke the API would only surface for users.

(.sys.exec "pkill -KILL -f '[r]ayforce -l /tmp/rftest_jwr' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jwr*")
(.sys.exec "./rayforce -l /tmp/rftest_jwr -p 19994 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19994) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hD (.ipc.open "127.0.0.1:19994"))
;; Journal a string-eval entry manually.  On replay this string will
;; be re-evaluated (string payloads go through ray_eval_str), binding d1.
(.ipc.send hD "(.log.write \"(set d1 999)\")")
(.ipc.close hD)
(.sys.exec "pkill -TERM -f '[r]ayforce -l /tmp/rftest_jwr -p 19994' 2>/dev/null; true")
(.sys.exec "for i in $(seq 30); do pgrep -f '[r]ayforce -l /tmp/rftest_jwr -p 19994' >/dev/null || exit 0; sleep 0.1; done; exit 1") -- 0

(.sys.exec "./rayforce -l /tmp/rftest_jwr -p 19994 </dev/null >/dev/null 2>&1 &")
(.sys.exec "for i in $(seq 30); do bash -c '(echo > /dev/tcp/127.0.0.1/19994) 2>/dev/null' && exit 0; sleep 0.1; done; exit 1") -- 0

(set hD2 (.ipc.open "127.0.0.1:19994"))
(.ipc.send hD2 "d1") -- 999
(.ipc.close hD2)
(.sys.exec "pkill -KILL -f '[r]ayforce -l /tmp/rftest_jwr' 2>/dev/null; true")
(.sys.exec "rm -f /tmp/rftest_jwr*")
