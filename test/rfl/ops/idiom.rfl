;; (count (distinct v)) — must equal hand-written reference
(set V [1 1 2 2 3 3 4 4 5])
(count (distinct V)) -- 5
;; value-check: dedup keeps the 5 unique values, sorted
(distinct V) -- [1 2 3 4 5]

;; with nulls (null is a distinct value; count includes it)
(count (distinct [1 0Nl 2 0Nl 1])) -- 3
;; value-check: numeric distinct sorts; null is least value, kept once
(distinct [1 0Nl 2 0Nl 1]) -- [0Nl 1 2]

;; empty
(count (distinct (as 'I64 ()))) -- 0

;; single element
(count (distinct [42])) -- 1
(distinct [42]) -- [42]

;; all equal
(count (distinct [7 7 7 7 7])) -- 1
(distinct [7 7 7 7 7]) -- [7]

;; cardinality-preserving rewrites
(count (asc     [3 1 4 1 5 9 2 6])) -- 8
(count (desc    [3 1 4 1 5 9 2 6])) -- 8
(count (reverse [3 1 4 1 5 9 2 6])) -- 8
;; value-check: asc sorts up, desc sorts down, reverse flips input order
(asc     [3 1 4 1 5 9 2 6]) -- [1 1 2 3 4 5 6 9]
(desc    [3 1 4 1 5 9 2 6]) -- [9 6 5 4 3 2 1 1]
(reverse [3 1 4 1 5 9 2 6]) -- [6 2 9 5 1 4 1 3]

;; with nulls — asc/desc/reverse preserve nulls; count includes them
(count (asc [1 0Nl 2])) -- 3
;; value-check: null is least value, sorts to the front under asc
(asc [1 0Nl 2]) -- [0Nl 1 2]

;; (first (asc v)) on null-free input — should equal (min v)
(first (asc [3 1 4 1 5 9 2 6])) -- 1
(last  (asc [3 1 4 1 5 9 2 6])) -- 9

;; (first (asc v)) on null-bearing input — in this codebase, both
;; first and min skip nulls, so semantics match.  The precondition
;; fires false for null-bearing OP_CONST (conservative), so the
;; slow path runs and must still produce the correct answer.
(first (asc [1 0Nl 2])) -- 1

;; (last (asc v)) on null-bearing input — last after asc is the
;; largest non-null in this case (nulls at the start).
(last (asc [1 0Nl 2])) -- 2
