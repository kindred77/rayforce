;; ====================================================================
;; ray_graph_k_shortest_fn — branch coverage (lines 629-652)
;; ====================================================================

;; wrong arity -> rank error (line 630)
(.graph.k-shortest Wg 0 1)                               !- rank
(.graph.k-shortest Wg 0 1 2 99)                          !- rank

;; non-handle -> type error (line 632)
(.graph.k-shortest 42 0 1 2)                             !- type

;; non-int src/dst/k -> type error (line 633-634)
(.graph.k-shortest Wg "bad" 1 2)                         !- type
(.graph.k-shortest Wg 0 "bad" 2)                         !- type
(.graph.k-shortest Wg 0 1 "bad")                         !- type

;; k=0 -> domain error (line 638, k_v <= 0)
(.graph.k-shortest Wg 0 1 0)                             !- domain

;; k=-1 -> domain error (line 638, k_v <= 0)
(.graph.k-shortest Wg 0 1 -1)                            !- domain

;; k=65536 -> domain error (line 638, k_v > 65535)
(.graph.k-shortest Wg 0 1 65536)                         !- domain

;; no weight -> schema error (line 640)
(.graph.k-shortest Uw 0 1 2)                             !- schema

;; ====================================================================
;; ray_graph_shortest_path_fn — branch coverage (lines 659-684)
;; ====================================================================

;; wrong arity -> rank error (line 660)
(.graph.shortest-path Uw 0)                              !- rank
(.graph.shortest-path Uw 0 1 2 99)                       !- rank

;; non-handle -> type error (line 662)
(.graph.shortest-path 42 0 1)                            !- type

;; non-int src/dst -> type error (line 663)
(.graph.shortest-path Uw "bad" 1)                        !- type
(.graph.shortest-path Uw 0 "bad")                        !- type

;; non-int max_depth -> type error (line 668)
(.graph.shortest-path Uw 0 1 "bad")                      !- type

;; max_depth=0 -> domain error (line 670, v <= 0)
(.graph.shortest-path Uw 0 1 0)                          !- domain

;; max_depth=-1 -> domain error (line 670, v <= 0)
(.graph.shortest-path Uw 0 1 -1)                         !- domain

;; max_depth=256 -> domain error (line 670, v > 255)
(.graph.shortest-path Uw 0 1 256)                        !- domain

;; ====================================================================
;; ray_graph_expand_fn — branch coverage (lines 688-718)
;; ====================================================================

;; wrong arity -> rank error (line 689)
(.graph.expand Uw)                                       !- rank
(.graph.expand Uw 0 1 99)                                !- rank

;; non-handle -> type error (line 691)
(.graph.expand 42 0)                                     !- type

;; non-int src -> type error (line 692)
(.graph.expand Uw "bad")                                 !- type

;; non-int direction -> type error (line 696)
(.graph.expand Uw 0 "bad")                               !- type

;; direction=-1 -> domain error (line 698, v < 0)
(.graph.expand Uw 0 -1)                                  !- domain

;; direction=3 -> domain error (line 698, v > 2)
(.graph.expand Uw 0 3)                                   !- domain

;; direction=2 (both) -> valid
(>= (count (.graph.expand Uw 0 2)) 1)                   -- true

;; ====================================================================
;; ray_graph_var_expand_fn — branch coverage (lines 721-762)
;; ====================================================================

;; wrong arity -> rank error (line 722)
(.graph.var-expand Uw 0 1)                               !- rank
(.graph.var-expand Uw 0 1 2 0 true 99)                   !- rank

;; non-handle -> type error (line 724)
(.graph.var-expand 42 0 1 2)                             !- type

;; non-int src/min/max -> type error (line 725-726)
(.graph.var-expand Uw "bad" 1 2)                         !- type
(.graph.var-expand Uw 0 "bad" 2)                         !- type
(.graph.var-expand Uw 0 1 "bad")                         !- type

;; min < 0 -> domain error (line 730)
(.graph.var-expand Uw 0 -1 2)                            !- domain

;; min > 255 -> domain error (line 730)
(.graph.var-expand Uw 0 256 257)                         !- domain

;; max < min -> domain error (line 730)
(.graph.var-expand Uw 0 5 3)                             !- domain

;; max > 255 -> domain error (line 730)
(.graph.var-expand Uw 0 1 256)                           !- domain

;; non-int direction -> type error (line 735)
(.graph.var-expand Uw 0 1 2 "bad")                       !- type

;; direction=-1 -> domain error (line 737, v < 0)
(.graph.var-expand Uw 0 1 2 -1)                          !- domain

;; direction=3 -> domain error (line 737, v > 2)
(.graph.var-expand Uw 0 1 2 3)                           !- domain

;; non-bool/non-int track -> type error (line 741-742)
(.graph.var-expand Uw 0 1 2 0 "bad")                     !- type

;; track as integer (1) -> exercises atom_to_i64 path (line 744)
(>= (count (.graph.var-expand Uw 0 1 2 0 1)) 1)         -- true

;; track as integer (0) -> exercises atom_to_i64 path (line 744)
(>= (count (.graph.var-expand Uw 0 1 2 0 0)) 1)         -- true

;; ====================================================================
;; Supplemental: pagerank with integer damping that converts to valid
;; float.  In practice integer damping always fails domain (0 or >= 1),
;; but the atom_to_i64 branch is still exercised.
;; ====================================================================

;; I32 atom as pagerank iter (atom_to_i64 I32 branch, line 78)
(count (.graph.pagerank Uw 5i))                          -- 3

;; I16 atom as pagerank iter (atom_to_i64 I16 branch, line 79)
(count (.graph.pagerank Uw 5h))                          -- 3

;; I32 atom as dfs max_depth (atom_to_i64 I32 branch)
(>= (count (.graph.dfs Uw 0 2i)) 1)                     -- true

;; I16 atom as dfs max_depth (atom_to_i64 I16 branch)
(>= (count (.graph.dfs Uw 0 2h)) 1)                     -- true

;; I32 atom as betweenness sample
(count (.graph.betweenness Uw 0i))                       -- 3

;; I32 atom as closeness sample
(>= (count (.graph.closeness Uw 0i)) 1)                 -- true

;; I32 atom as louvain iter
(count (.graph.louvain Uw 10i))                          -- 3

;; I32 atom as random-walk walk_len
(>= (count (.graph.random-walk Uw 0 3i)) 1)             -- true

;; I32 atom as expand direction
(>= (count (.graph.expand Uw 0 0i)) 1)                  -- true

;; I32 atom as shortest-path max_depth
(>= (count (.graph.shortest-path Uw 0 1 5i)) 1)         -- true

;; I32 atom as dijkstra max_depth
(>= (count (.graph.dijkstra Wg 0 1 5i)) 1)              -- true

;; ====================================================================
;; Build with string column names (arg_to_sym STR path, line 90-96)
;; ====================================================================
(set StrG (.graph.build UwEdges "src" "dst"))
(at (.graph.info StrG) 'n_nodes)                         -- 3
(.graph.free StrG)

;; ====================================================================
;; Build with string weight column name
;; ====================================================================
(set StrWg (.graph.build WEdges "src" "dst" "w"))
(at (.graph.info StrWg) 'has_weights)                    -- true
(.graph.free StrWg)

;; ====================================================================
;; Cleanup
;; ====================================================================
(.graph.free Uw)
(.graph.free Wg)
