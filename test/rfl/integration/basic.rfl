null -- null
0x1a -- 0x1a
[0x1a 0x1b] -- [0x1a 0x1b]
true -- true
false -- false
1 -- 1
1.1 -- 1.10
(as 'i64 " 1") -- 1
0.6 -- 0.60
0.599999999999999999 -- 0.60
0.599999999999999999999999999999999999999999999999999999999999999 -- 0.60
1.000000123555555555555555555555555e-02 -- 0.01
1.000000123555555555555555555555555e-01 -- 0.10
1.000000123555555555555555555555555e-00 -- 1.00
(as 'f64 " 1.000000123555555555555555555555555e+01") -- 10.00
-1000123555555555555555555555555 -- -1.000124e+30
33000h !- domain
-10001230000i !- domain
"" -- ""
'asd -- 'asd
' -- '
(as 'STR ') -- ""
(as 'STR ' ) -- ""
"asd" -- "asd"
{a: "asd" b: 1 c: [1 2 3]} -- {a: "asd" b: 1 c: [1 2 3]}
{a: "asd" b: 1 c: [1 2 3] d: {e: 1 f: 2}} -- {a: "asd" b: 1 c: [1 2 3] d: {e: 1 f: 2}}
{a: "asd" b: 1 c: [1 2 3] d: {e: 1 f: 2 g: {h: 1 i: 2}}} -- {a: "asd" b: 1 c: [1 2 3] d: {e: 1 f: 2 g: {h: 1 i: 2}}}
(list 1 2 3 "asd") -- (list 1 2 3 "asd")
(list 1 2 3 "asd" (list 1 2 3)) -- (list 1 2 3 "asd" (list 1 2 3))
(list 1 2 3 "asd" (list 1 2 3 (list 1 2 3))) -- (list 1 2 3 "asd" (list 1 2 3 (list 1 2 3)))
(list 1 2 3) -- (list 1 2 3)
(enlist 1 2 3) -- [1 2 3]
