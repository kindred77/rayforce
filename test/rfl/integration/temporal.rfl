;; Ported from test_lang_rf.inc::test_rf_temporal.

;; ========== DATE ARITHMETIC ==========
(+ 2024.01.01 1) -- 2024.01.02
(+ 2024.01.01 30) -- 2024.01.31
(+ 2024.01.01 31) -- 2024.02.01
(- 2024.01.10 5) -- 2024.01.05
(- 2024.02.01 2024.01.01) -- 31
;; ========== TIME ARITHMETIC ==========
(+ 10:00:00.000 1000) -- 10:00:01.000
(+ 10:00:00.000 60000) -- 10:01:00.000
(+ 10:00:00.000 3600000) -- 11:00:00.000
(- 10:00:01.000 1000) -- 10:00:00.000
(- 10:00:01.000 10:00:00.000) -- 00:00:01.000
;; ========== TIMESTAMP ARITHMETIC ==========
(+ 2024.01.01D10:00:00.000000000 1000000000) -- 2024.01.01D10:00:01.000000000
(- 2024.01.01D10:00:01.000000000 1000000000) -- 2024.01.01D10:00:00.000000000
;; ========== VECTOR OPERATIONS ==========
(+ [2024.01.01 2024.01.02] 1) -- [2024.01.02 2024.01.03]
(- [2024.01.10 2024.01.20] [2024.01.01 2024.01.10]) -- [9 10]
