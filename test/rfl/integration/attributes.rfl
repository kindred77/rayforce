;; ===== sorted marker: set / get / drop =====
;; set on an ascending vector succeeds and round-trips through get
(set v [1 2 2 5 9])(.attr.get (.attr.set 'sorted v)) -- ['sorted]
;; set on a non-ascending vector errors (verify failure -> domain)
(.attr.set 'sorted [3 1 2]) !- domain
;; get on a plain vector is the empty symbol vector
(.attr.get [1 2 3]) -- (take ['a] 0)
;; drop clears the marker
(.attr.get (.attr.drop (.attr.set 'sorted [1 2 3]))) -- (take ['a] 0)
;; unknown attribute name errors (unknown attribute -> domain)
(.attr.set 'bogus [1 2 3]) !- domain
;; ===== sorted on TIME columns (4-byte int32 — the asof time type) =====
;; ascending TIME vector accepts sorted
(.attr.get (.attr.set 'sorted [10:00:01.000 10:00:02.000 10:00:03.000])) -- ['sorted]
;; non-ascending TIME vector is rejected (proves element width is read correctly)
(.attr.set 'sorted [10:00:03.000 10:00:01.000]) !- domain
;; ===== unique marker =====
(.attr.get (.attr.set 'unique [1 2 3 4])) -- ['unique]
(.attr.set 'unique [1 2 2 4]) !- domain
;; sorted + unique coexist (sorted in attrs, unique in the block)
(.attr.get (.attr.set 'unique (.attr.set 'sorted [1 2 3]))) -- ['sorted 'unique]
;; ===== grouped (hash-backed) =====
(.idx.has? (.attr.set 'grouped [1 1 2 3 3])) -- true
(.attr.get (.attr.set 'grouped [1 1 2 3 3])) -- ['grouped]
;; unique then grouped: the unique marker is preserved alongside the hash index
(.attr.get (.attr.set 'grouped (.attr.set 'unique [1 2 3 4]))) -- ['unique 'grouped]
;; grouped then unique: exercises the clone-shared-index-block branch of attr.set unique
(.attr.get (.attr.set 'unique (.attr.set 'grouped [1 2 3 4]))) -- ['unique 'grouped]
;; drop clears a block-resident marker (unique) and its backing block
(.idx.has? (.attr.drop (.attr.set 'unique [1 2 3]))) -- false
(.attr.get (.attr.drop (.attr.set 'unique [1 2 3]))) -- (take ['a] 0)
;; ===== parted (contiguous ascending value-blocks) =====
;; a column laid out as ascending value-blocks accepts parted
(.attr.get (.attr.set 'parted [1 1 1 2 2 3])) -- ['parted]
;; .idx.info reports the part kind and the part count
(at (.idx.info (.attr.set 'parted [1 1 2 2])) 'kind) -- 'part
(at (.idx.info (.attr.set 'parted [1 1 2 2])) 'n_parts) -- 2
;; a non-blocked column is rejected (verify-only: no reorder)
(.attr.set 'parted [1 2 1 2]) !- domain
;; descending blocks rejected (blocks must be ascending)
(.attr.set 'parted [3 3 1 1]) !- domain
;; unique coexists with parted (exercises clone_index_block on a PART block)
(.attr.get (.attr.set 'unique (.attr.set 'parted [1 2 3 4]))) -- ['unique 'parted]
;; parted on a TIME column (the asof partition/time use case is numeric/temporal)
(.attr.get (.attr.set 'parted [10:00:01.000 10:00:01.000 10:00:02.000])) -- ['parted]
;; edge cases: single-element, float value-blocks, and empty column
(.attr.get (.attr.set 'parted [5])) -- ['parted]
(.attr.get (.attr.set 'parted [1.0 1.0 2.0])) -- ['parted]
(.attr.get (.attr.set 'parted (take [1] 0))) -- ['parted]

;; ===== conservative invalidation: transforms drop attributes =====
;; A transformed/derived vector must NOT inherit its input's attributes:
;; a stale 'sorted marker or backing index would let a later asof-join
;; trust a wrong ordering claim. Only a plain copy/rebind preserves them.
;; arithmetic on a sorted column yields an unattributed result
(.attr.get (+ (.attr.set 'sorted [1 2 3]) 1)) -- (take ['a] 0)
;; arithmetic on a grouped (indexed) column drops the backing index
(.idx.has? (+ (.attr.set 'grouped [1 2 3]) 1)) -- false
;; a second arithmetic op (multiply) likewise drops the sorted marker
(.attr.get (* (.attr.set 'sorted [1 2 3]) 2)) -- (take ['a] 0)
;; multiply on a grouped column drops the backing index
(.idx.has? (* (.attr.set 'grouped [1 2 3]) 2)) -- false
;; take (prefix) of a sorted column does NOT carry the marker (conservative)
(.attr.get (take (.attr.set 'sorted [1 2 3 4 5]) 3)) -- (take ['a] 0)
;; take of a grouped column does not carry the backing index
(.idx.has? (take (.attr.set 'grouped [1 1 2 3 3]) 3)) -- false
;; reverse of a sorted column drops the marker (order is now descending)
(.attr.get (reverse (.attr.set 'sorted [1 2 3]))) -- (take ['a] 0)
;; reverse of a grouped column drops the backing index
(.idx.has? (reverse (.attr.set 'grouped [1 1 2 3 3]))) -- false
;; concat of a sorted column with more data drops the marker
(.attr.get (concat (.attr.set 'sorted [1 2 3]) [0 1])) -- (take ['a] 0)
;; concat of a grouped column drops the backing index
(.idx.has? (concat (.attr.set 'grouped [1 1 2 3 3]) [4 5])) -- false
;; where-filtered selection off a sorted column drops the marker
(.attr.get (at (.attr.set 'sorted [1 2 3 4 5]) (where [true false true false true]))) -- (take ['a] 0)
;; a plain rebind PRESERVES the marker (trivially-preserving)
(set _s (.attr.set 'sorted [1 2 3]))(.attr.get _s) -- ['sorted]
;; a plain rebind PRESERVES the backing index too
(set _g (.attr.set 'grouped [1 1 2 3 3]))(.idx.has? _g) -- true
