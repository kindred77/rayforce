(min 0Nf) -- 0Nf
(min 5i) -- 5i
(min -1.7) -- -1.7
(min -24) -- -24
(min 2020.03.05) -- 2020.03.05
(min -00:00:05.000) -- -00:00:05.000
(min 1999.03.13D11:45:43.848458167) -- 1999.03.13D11:45:43.848458167
(min [1i 2i -3i]) -- -3i
(min [0Ni -24i 12i 6i]) -- -24i
(min [1.0 2.0 3.0 0Nf]) -- 1.0
(min [-24 12 6 0Nl]) -- -24
(min [0Ni]) -- 0Ni
(min [2020.03.05]) -- 2020.03.05
(min [-00:00:05.000]) -- -00:00:05.000
(min [1999.03.13D11:45:43.848458167]) -- 1999.03.13D11:45:43.848458167
(min []) -- 0Nl
;; u8 min
(min 0x05) -- 0x05
(min [0x05 0x01 0x03]) -- 0x01
(min (take 0x05 100000)) -- 0x05
;; large u8 vector
;; i16 min
(min 5h) -- 5h
(min [5h 1h 3h]) -- 1h
(min [0Nh 5h 1h]) -- 1h
(min (take 10h 100000)) -- 10h
