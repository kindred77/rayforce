(max -00:00:05.000) -- -00:00:05.000
(max 1999.03.13D11:45:43.848458167) -- 1999.03.13D11:45:43.848458167
(max [1i 2i -3i]) -- 2i
(max [0Ni -24i 12i 6i]) -- 12i
(max [1.0 2.0 3.0 0Nf]) -- 3.0
(max [-24 12 6 0Nl]) -- 12
(max [0Ni]) -- 0Ni
(max [2020.03.05]) -- 2020.03.05
(max [-00:00:05.000]) -- -00:00:05.000
(max [1999.03.13D11:45:43.848458167]) -- 1999.03.13D11:45:43.848458167
(max []) -- 0Nl
;; u8 max
(max 0x05) -- 0x05
(max [0x05 0x01 0x03]) -- 0x05
(max (take 0x05 100000)) -- 0x05
;; large u8 vector
;; i16 max
(max 5h) -- 5h
(max [5h 1h 3h]) -- 5h
(max [0Nh 5h 1h]) -- 5h
(max (take 10h 100000)) -- 10h
;; large i16 vector
(round []) -- []
(round -0.5) -- -1.0
(round [-1.5 -1.1 -0.0 0Nf 0.0 1.1 1.5]) -- [-2.0 -1.0 0.0 0Nf 0.0 1.0 2.0]
(round 0Nf) -- 0Nf
(floor [1.1 2.5 -1.1]) -- [1.0 2.0 -2.0]
(floor -0.0) -- 0.0
(floor [-1.0 3.0]) -- [-1.0 3.0]
(floor 0.0) -- 0.0
(floor 1.0) -- 1.0
(floor -1.0) -- -1.0
(floor 1.5) -- 1.0
(floor -1.5) -- -2.0
(floor 0Nf) -- 0Nf
(floor -5i) -- -5i
(floor 'i64) !- type
(ceil -5i) -- -5i
(ceil [1.1 2.5 -1.1]) -- [2.0 3.0 -1.0]
(ceil -0.0) -- 0.0
(ceil [-1.0 3.0]) -- [-1.0 3.0]
(ceil 0.0) -- 0.0
(ceil 1.0) -- 1.0
(ceil -1.0) -- -1.0
(ceil 1.5) -- 2.0
(ceil -1.5) -- -1.0
(ceil 0Nf) -- 0Nf
(ceil 'i64) !- type
(med 2i) -- 2.0
(med -5) -- -5.0
(med 0Nf) -- 0Nf
(med []) -- 0Nf
