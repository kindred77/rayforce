;; ASSERT_EQ("(med [1.0 2.0 3.0 4.0 0Nf 0Nf])", "2.5");
;; u8 med
(med 0x05) -- 5.0
(med [0x03 0x01 0x02]) -- 2.0
(med [0x04 0x03 0x01 0x02]) -- 2.5
;; i16 med
(med 5h) -- 5.0
(med [3h 1h 2h]) -- 2.0
(med [4h 3h 1h 2h]) -- 2.5
(dev 1) -- 0.0
(dev [0Ni]) -- 0Nf
(dev [1i 2i]) -- 0.5
(dev [1 0Nl 2]) -- 0.5
(dev [1 2 3 4 50]) -- 19.0263
(dev [0Nl 1 2 3 4 50 0Nl]) -- 19.0263
(dev [0Nf -2.0 10.0 11.0 5.0 0Nf]) -- 5.147815
;; u8 dev
(dev 0x05) -- 0.0
(dev [0x01 0x01 0x01]) -- 0.0
(dev [0x01 0x02]) -- 0.5
;; i16 dev
(dev 5h) -- 0.0
(dev [1h 1h 1h]) -- 0.0
(dev [1h 2h]) -- 0.5
(dev [1h 0Nh 2h]) -- 0.5
