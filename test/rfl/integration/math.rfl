((fn [x y] (+ x y)) 1 [2.3 4]) -- [3.3 5.0]
;; ========== TYPE CONVERSION TESTS (I64 * F64 -> F64) ==========
;; Test that multiplying integer vector by float scalar returns correct float values
;; (regression test for buffer reuse type mismatch bug)
(* [75000 65000 85000] 1.1) -- [82500.0 71500.0 93500.0]
(* [100 200 300] 1.5) -- [150.0 300.0 450.0]
(* 1.1 [75000 65000 85000]) -- [82500.0 71500.0 93500.0]
;; Test I32 * F64 -> F64
(* [75000i 65000i 85000i] 1.1) -- [82500.0 71500.0 93500.0]
;; Test division with type conversion
(/ [100 200 300] 3.0) -- [33 66 100]
(% [100 200 300] 3.0) -- [1.0 2.0 0.0]
