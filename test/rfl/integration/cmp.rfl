;; Ported from test_lang_rf.inc::test_rf_cmp.

;; Test character-to-string comparisons
(== 'a' "a") -- true
(== 'a' "b") -- false
(== 'a' "ab") -- false
(== "a" 'a') -- true
(== "ab" 'a') -- false
(!= 'a' "b") -- true
(!= 'a' "a") -- false
(!= "a" 'b') -- true
(!= "a" 'a') -- false
(< 'a' "b") -- true
(< 'b' "a") -- false
(< "a" 'b') -- true
(< "b" 'a') -- false
(> 'b' "a") -- true
(> 'a' "b") -- false
(> "b" 'a') -- true
(> "a" 'b') -- false
(<= 'a' "a") -- true
(<= 'a' "b") -- true
(<= 'b' "a") -- false
(<= "a" 'a') -- true
(<= "a" 'b') -- true
(<= "b" 'a') -- false
(>= 'a' "a") -- true
(>= 'b' "a") -- true
(>= 'a' "b") -- false
(>= "a" 'a') -- true
(>= "b" 'a') -- true
(>= "a" 'b') -- false
;; Test character-to-character comparisons
(== 'a' 'a') -- true
(== 'a' 'b') -- false
(!= 'a' 'b') -- true
(!= 'a' 'a') -- false
(< 'a' 'b') -- true
(< 'b' 'a') -- false
(> 'b' 'a') -- true
(> 'a' 'b') -- false
(<= 'a' 'a') -- true
(<= 'a' 'b') -- true
(<= 'b' 'a') -- false
(>= 'a' 'a') -- true
(>= 'b' 'a') -- true
(>= 'a' 'b') -- false
;; Test string-to-string comparisons
(== "a" "a") -- true
(== "a" "b") -- false
(== "ab" "ab") -- true
(== "ab" "ac") -- false
(!= "a" "b") -- true
(!= "a" "a") -- false
(< "a" "b") -- true
(< "b" "a") -- false
(> "b" "a") -- true
(> "a" "b") -- false
(<= "a" "a") -- true
(<= "a" "b") -- true
(<= "b" "a") -- false
(>= "a" "a") -- true
(>= "b" "a") -- true
(>= "a" "b") -- false
