;; Ported from test_lang_rf.inc::test_rf_aggregations.

;; ========== SUM TESTS ==========
(sum [1 2 3 4 5]) -- 15
(sum [1.0 2.0 3.0]) -- 6.0
(sum [1i 2i 3i]) -- 6i
(sum []) -- 0
(sum 5) -- 5
;; scalar
;; ========== AVG TESTS ==========
(avg [1 2 3 4 5]) -- 3.0
(avg [10.0 20.0 30.0]) -- 20.0
(avg [2 4 6 8]) -- 5.0
(avg 10) -- 10.0
;; scalar
;; ========== MIN TESTS ==========
(min [5 2 8 1 9]) -- 1
(min [5.0 2.0 8.0]) -- 2.0
(min [-5 -2 -8]) -- -8
(min [5i 2i 8i]) -- 2i
(min 42) -- 42
;; scalar
;; ========== MAX TESTS ==========
(max [5 2 8 1 9]) -- 9
(max [5.0 2.0 8.0]) -- 8.0
(max [-5 -2 -8]) -- -2
(max [5i 2i 8i]) -- 8i
(max 42) -- 42
;; scalar
;; ========== COUNT TESTS ==========
(count [1 2 3 4 5]) -- 5
(count []) -- 0
(count "hello") -- 5
(count (dict [a b c] [1 2 3])) -- 3
(count (table [a b] (list [1 2 3] [4 5 6]))) -- 3
(count 5) -- 1
;; scalar
;; ========== FIRST TESTS ==========
(first [1 2 3 4 5]) -- 1
(first "hello") -- 'h'
(first ['a 'b 'c]) -- 'a
(first (table [a b] (list [1 2 3] [4 5 6]))) -- {a:1 b:4}
;; ========== LAST TESTS ==========
(last [1 2 3 4 5]) -- 5
(last "hello") -- 'o'
(last ['a 'b 'c]) -- 'c
(last (table [a b] (list [1 2 3] [4 5 6]))) -- {a:3 b:6}
;; ========== MED (MEDIAN) TESTS ==========
(med [1 2 3 4 5]) -- 3.0
(med [1 2 3 4]) -- 2.5
(med [5 1 3 2 4]) -- 3.0
;; unsorted input
;; ========== DEV (STANDARD DEVIATION) TESTS ==========
(dev [1 1 1 1]) -- 0.0
(< (- (dev [1 2 3 4 5]) 1.4142) 0.001) -- true
;; approx sqrt(2);
;; ========== AGGREGATIONS ON TABLES WITH GROUPBY ==========
(set t (table [Group Value] (list [a a b b] [10 20 30 40])))(select {from: t Total: (sum Value) by: Group}) -- (table [Group Total] (list [a b] [30 70]))
(set t (table [Group Value] (list [a a b b] [10 20 30 40])))(select {from: t Avg: (avg Value) by: Group}) -- (table [Group Avg] (list [a b] [15.0 35.0]))
(set t (table [Group Value] (list [a a b b] [10 20 30 40])))(select {from: t Min: (min Value) Max: (max Value) by: Group}) -- (table [Group Min Max] (list [a b] [10 30] [20 40]))
(set t (table [Group Value] (list [a a a b b] [1 2 3 4 5])))(select {from: t Cnt: (count Value) by: Group}) -- (table [Group Cnt] (list [a b] [3 2]))
