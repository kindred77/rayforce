;; Invariants for `find`.

(find [10 20 30] 20) -- 1
(find [10 20 30] 10) -- 0
(find [10 20 30] 30) -- 2

;; missing element → typed null (rayforce behaviour)
(find [10 20 30] 99) -- 0Nl

;; roundtrip: (at V (find V x)) == x when x is present
(set V [7 11 13 17 19])
(at V (find V 13)) -- 13
(at V (find V 7)) -- 7

;; ---- Regression tests ported from test_lang_rf.inc::test_rf_find ----
;; Ported from test_lang_rf.inc::test_rf_find.

;; ========== FIND IN VECTOR ==========
(find [10 20 30 40] 30) -- 2
(find [10 20 30 40] 50) -- 0Nl
;; not found
(find [10 20 30 40] 10) -- 0
(find ['a 'b 'c] 'b) -- 1
(find "hello" 'l') -- 2
;; ========== FIND MULTIPLE ==========
(find [10 20 30 40] [20 40]) -- [1 3]
(find ['a 'b 'c 'd] ['c 'a]) -- [2 0]
(find [1 2 3] [4 2 5]) -- [0Nl 1 0Nl]
;; ========== FIND IN EMPTY ARRAY ==========
(find [] 1) -- 0Nl
(find [] [1 2 3]) -- [0Nl 0Nl 0Nl]
;; Empty source → all not-found (0Nl per element)
;; ========== FIND WITH DIFFERENT TYPE WIDTHS (index_find_i8) ==========
(find "abc" 'b') -- 1
(find "abc" 'z') -- 0Nl
(find "" 'a') -- 0Nl
;; ========== FIND WITH i64 (index_find_i64) ==========
(find [1000000000 2000000000 3000000000] 2000000000) -- 1
(find [1000000000 2000000000] 9999999999) -- 0Nl
;; ========== FIND WITH SYMBOLS ==========
(find ['apple 'banana 'cherry] 'banana) -- 1
(find ['a] 'a) -- 0
(find ['a] 'b) -- 0Nl
