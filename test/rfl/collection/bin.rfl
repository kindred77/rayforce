;; Invariants for `bin` — binary-search insertion index.

(bin [1 3 5 7 9] 4) -- 1
(bin [1 3 5 7 9] 1) -- 0
(bin [1 3 5 7 9] 9) -- 4
(bin [1 3 5 7 9] 100) -- 4
(bin [1 3 5 7 9] -1) -- -1

;; result in [-1, count(sorted)-1]
(set S (asc (rand 100 1000)))
(set X (rand 50 1000))
(count X) -- (sum (and (>= (bin S X) -1) (< (bin S X) (count S))))

;; ---- Regression tests ported from test_lang_rf.inc::test_rf_bin ----
;; Ported from test_lang_rf.inc::test_rf_bin.

(bin [1 2 3 4 5] 3) -- 2
(bin [0 2 4 6 8 10] 5) -- 2
(bin [0 2 4 6 8 10] [-10 0 4 5 6 20]) -- [-1 0 2 2 3 5]
(bin [0 1 1 2] [0 1 2]) -- [0 2 3]
(binr [0 1 1 2] [0 1 2]) -- [0 1 3]
