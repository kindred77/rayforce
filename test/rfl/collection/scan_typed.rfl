;; Typed prefix-scan kernels (scan_typed_arith, collection.c): (scan +|* vec)
;; over F64/I64/I32/I16 typed vectors returns a TYPED VECTOR computed in one
;; tight loop — not a LIST of boxed atoms from per-element call machinery.
;; Per-step semantics must mirror ray_add_fn/ray_mul_fn exactly.

;; typed output + values
(scan + [1 2 3 4]) -- [1 3 6 10]
(type (scan + [1 2 3 4])) -- 'I64
(scan + [1.5 2.5 3.0]) -- [1.5 4.0 7.0]
(type (scan + [1.5 2.5 3.0])) -- 'F64
(scan * [2 3 4]) -- [2 6 24]
(scan * [1.5 2.0 3.0]) -- [1.5 3.0 9.0]

;; width preservation (generic path kept i32/i16 element widths)
(type (scan + (as 'I32 [1 2 3]))) -- 'I32
(scan + (as 'I32 [1 2 3])) -- (as 'I32 [1 3 6])
(type (scan + (as 'I16 [1 2 3]))) -- 'I16

;; null propagation is sticky (mirrors boxed null_for_promoted)
(scan + (as 'F64 (list 1.5 0Nf 3.0))) -- [1.5 0Nf 0Nf]
(scan + (as 'I64 (list 1 0N 3))) -- (as 'I64 (list 1 0N 0N))
(scan * (as 'I64 (list 2 0N 3))) -- (as 'I64 (list 2 0N 0N))

;; single element / first element identity
(scan + [7]) -- [7]
(scan + [42.5]) -- [42.5]

;; LIST inputs and lambda fns keep the generic path (boxed atoms)
(scan + (list 1 2 3)) -- (list 1 3 6)
(type (scan + (list 1 2 3))) -- 'LIST
(scan (fn [a b] (+ a b)) [1 2 3]) -- (list 1 3 6)
(count (scan + (list))) -- 0
(type (scan + (list))) -- 'LIST

;; subtraction / division stay generic (no typed kernel)
(scan - [10 1 2]) -- (list 10 9 7)
