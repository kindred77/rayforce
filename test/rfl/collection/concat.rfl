;; Invariants for `concat`.

(concat [1 2] [3 4]) -- [1 2 3 4]
(concat [] [1 2]) -- [1 2]
(concat [1 2] []) -- [1 2]

;; count is additive
(set A (rand 50 1000))
(set B (rand 80 1000))
(count (concat A B)) -- (+ (count A) (count B))

;; associative (via count)
(set C (rand 30 1000))
(count (concat (concat A B) C)) -- (count (concat A (concat B C)))

;; first of concat is first of first (when non-empty)
(first (concat [7 8 9] [10 11])) -- 7

;; last of concat is last of second
(last (concat [7 8 9] [10 11])) -- 11

;; ---- Regression tests ported from test_lang_rf.inc::test_rf_concat ----
;; Ported from test_lang_rf.inc::test_rf_concat.

(concat true false) -- [true false]
(concat [true] false) -- [true false]
(concat true [false]) -- [true false]
(concat [true] [false]) -- [true false]
(concat 0x0d 0x0a) -- [0x0d 0x0a]
(concat [0x0d] 0x0a) -- [0x0d 0x0a]
(concat 0x0d [0x0a]) -- [0x0d 0x0a]
(concat [0x0d] [0x0a]) -- [0x0d 0x0a]
(concat 't' 's') -- "ts"
(concat 't' "est") -- "test"
(concat "tes" 't') -- "test"
(concat "te" "st") -- "test"
(concat 't' "est\000") -- "test"
(concat "tes\000" 't') -- "test"
(concat "te\000" "st\000") -- "test"
(concat 1h 2h) -- [1h 2h]
(concat [1h] 2h) -- [1h 2h]
(concat 1h [2h]) -- [1h 2h]
(concat [1h] [2h]) -- [1h 2h]
(concat 1i 2i) -- [1i 2i]
(concat [1i] 2i) -- [1i 2i]
(concat 1i [2i]) -- [1i 2i]
(concat [1i] [2i]) -- [1i 2i]
(concat 2020.10.10 2020.10.12) -- [2020.10.10 2020.10.12]
(concat [2020.10.10] 2020.10.12) -- [2020.10.10 2020.10.12]
(concat 2020.10.10 [2020.10.12]) -- [2020.10.10 2020.10.12]
(concat [2020.10.10] [2020.10.12]) -- [2020.10.10 2020.10.12]
(concat 10:00:00.000 10:00:00.001) -- [10:00:00.000 10:00:00.001]
(concat [10:00:00.000] 10:00:00.001) -- [10:00:00.000 10:00:00.001]
(concat 10:00:00.000 [10:00:00.001]) -- [10:00:00.000 10:00:00.001]
(concat [10:00:00.000] [10:00:00.001]) -- [10:00:00.000 10:00:00.001]
(concat 1 2) -- [1 2]
(concat [1] 2) -- [1 2]
(concat 1 [2]) -- [1 2]
(concat [1] [2]) -- [1 2]
(concat 'a 'b) -- ['a 'b]
(concat 'a ['b]) -- ['a 'b]
(concat ['a] 'b) -- ['a 'b]
(concat ['a] ['b]) -- ['a 'b]
(concat 2025.01.01D15:17:19.000000000 2025.01.02D15:17:19.000000002) -- [2025.01.01D15:17:19.000000000 2025.01.02D15:17:19.000000002]
(concat [2025.01.01D15:17:19.000000000] 2025.01.02D15:17:19.000000002) -- [2025.01.01D15:17:19.000000000 2025.01.02D15:17:19.000000002]
(concat 2025.01.01D15:17:19.000000000 [2025.01.02D15:17:19.000000002]) -- [2025.01.01D15:17:19.000000000 2025.01.02D15:17:19.000000002]
(concat [2025.01.01D15:17:19.000000000] [2025.01.02D15:17:19.000000002]) -- [2025.01.01D15:17:19.000000000 2025.01.02D15:17:19.000000002]
(concat 1.0 2.0) -- [1.0 2.0]
(concat [1.0] 2.0) -- [1.0 2.0]
(concat 1.0 [2.0]) -- [1.0 2.0]
(concat [1.0] [2.0]) -- [1.0 2.0]
(concat (dict [A B] (list (+ (til 4) 10) [16 17 18 19])) (dict [C A] (list (list "A" "B" "C" "D" "E") (til 5)))) -- (dict [A B C] (list (til 5) [16 17 18 19] (list "A" "B" "C" "D" "E")))
(concat (table [A C] (list (+ (til 4) 10) (list "a" "b" "c" "d"))) (table [C B A] (list (list "A" "B" "C" "D" "E") [100 200 300 400 500] (til 5)))) -- (table [A C] (list [10 11 12 13 0 1 2 3 4] (list "a" "b" "c" "d" "A" "B" "C" "D" "E")))
(concat (table [D C] (list (+ (til 4) 10) (list "a" "b" "c" "d"))) (table [C B A] (list (list "A" "B" "C" "D" "E") [100 200 300 400 500] (til 5)))) !- value
(concat (table [C A] (list (+ (til 4) 10) (list "a" "b" "c" "d"))) (table [C B A] (list (list "A" "B" "C" "D" "E") [100 200 300 400 500] (til 5)))) !- type
(concat (table [a] (list [1 2])) (table [a] (list [1.0]))) !- type
(concat (as 'guid "d49f18a4-1969-49e8-9b8a-6bb9a4832eea") (as 'guid "a49f18a4-1969-49e8-9b8a-6bb9a4832eea")) -- [d49f18a4-1969-49e8-9b8a-6bb9a4832eea a49f18a4-1969-49e8-9b8a-6bb9a4832eea]
(concat (as 'guid "d49f18a4-1969-49e8-9b8a-6bb9a4832eea") (enlist (as 'guid "a49f18a4-1969-49e8-9b8a-6bb9a4832eea"))) -- [d49f18a4-1969-49e8-9b8a-6bb9a4832eea a49f18a4-1969-49e8-9b8a-6bb9a4832eea]
(concat (enlist (as 'guid "d49f18a4-1969-49e8-9b8a-6bb9a4832eea")) (as 'guid "a49f18a4-1969-49e8-9b8a-6bb9a4832eea")) -- [d49f18a4-1969-49e8-9b8a-6bb9a4832eea a49f18a4-1969-49e8-9b8a-6bb9a4832eea]
(concat (list 'a') 5) -- (list 'a' 5)
(concat 5 (list 'a')) -- (list 5 'a')
(concat 'a' 5) -- (list 'a' 5)
