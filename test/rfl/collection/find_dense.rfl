;; find_dense.rfl — equivalence tests for the hashed dense-I64 vector find.
;;
;; vector-vals find now returns a dense I64 vec (not a boxed LIST), built
;; via a hashset over vec (O(n+m) for typed vecs) or per-element fallback
;; for LIST/mixed.  Hand-computed oracles for every required case.

;; ════════════════════════════════════════════════════════════════
;; 1. Result type is I64 (not LIST) — the primary regression guard
;; ════════════════════════════════════════════════════════════════
(type (find [10 20 30] [20 30 10])) -- 'I64

;; ════════════════════════════════════════════════════════════════
;; 2. Basic int vector find
;; ════════════════════════════════════════════════════════════════
(find [10 20 30] [20 30 10]) -- [1 2 0]
(find [10 20 30 40] [40 10 20]) -- [3 0 1]

;; ════════════════════════════════════════════════════════════════
;; 3. SYM vector find — exercises SYM cross-domain handling in hashset
;; ════════════════════════════════════════════════════════════════
(find ['a 'b 'c] ['b 'c]) -- [1 2]
(find ['apple 'banana 'cherry] ['cherry 'apple 'banana]) -- [2 0 1]

;; ════════════════════════════════════════════════════════════════
;; 4. Not-found element → 0Nl in the dense output
;; ════════════════════════════════════════════════════════════════
(find [10 20 30] [99 20]) -- [0Nl 1]
(find [10 20 30] [4 2 5]) -- [0Nl 0Nl 0Nl]

;; ════════════════════════════════════════════════════════════════
;; 5. Null in vec — null probe returns first-null index;
;;    non-null probe against null-bearing vec works normally
;; ════════════════════════════════════════════════════════════════
(find [0Nl 10 20] [10 0Nl 30]) -- [1 0 0Nl]

;; ════════════════════════════════════════════════════════════════
;; 6. Duplicate values in vec → first (lowest) index is returned
;; ════════════════════════════════════════════════════════════════
(find [10 20 10 30] [10 20]) -- [0 1]
(find [5 5 5] [5]) -- [0]

;; ════════════════════════════════════════════════════════════════
;; 7. Empty vec → all 0Nl (length matches vals, not 0)
;;    (was a latent bug returning empty vec; now fixed)
;; ════════════════════════════════════════════════════════════════
(find [] [1 2 3]) -- [0Nl 0Nl 0Nl]
(count (find [] [1 2 3])) -- 3

;; ════════════════════════════════════════════════════════════════
;; 8. Gather-back (fby shape): at agg (find keys rows)
;;    Per-group aggregate broadcast back to per-row positions.
;;    keys=['a 'b 'c], agg=[100 200 300], rows=['b 'a 'c 'a]
;;    find keys rows → [1 0 2 0]
;;    at agg [1 0 2 0] → 200 100 300 100
;; ════════════════════════════════════════════════════════════════
(set Gkeys ['a 'b 'c])
(set Gagg [100 200 300])
(set Grows ['b 'a 'c 'a])
(find Gkeys Grows) -- [1 0 2 0]
(at (at Gagg (find Gkeys Grows)) 0) -- 200
(at (at Gagg (find Gkeys Grows)) 1) -- 100
(at (at Gagg (find Gkeys Grows)) 2) -- 300
(at (at Gagg (find Gkeys Grows)) 3) -- 100
