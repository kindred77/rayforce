;; Time-series prefix/vector primitives. These are lazy-aware DAG ops for
;; vector inputs, with morsel summaries so block boundaries do not change
;; prefix state.

;; Forward fill keeps leading nulls null and carries the last non-null value.
(fills (as 'I64 (list 0N 2 0N 4 0N))) -- (as 'I64 (list 0N 2 2 4 4))
(fills (as 'F64 (list 0Nf 1.5 0Nf 3.0))) -- (as 'F64 (list 0Nf 1.5 1.5 3.0))
(fills [1 2 3]) -- [1 2 3]

;; Running aggregates skip null payloads. sum/prod use aggregate identities;
;; avg/min/max stay null until the first non-null value.
(sums [1 2 3 4]) -- [1 3 6 10]
(prds [2 3 4]) -- [2 6 24]
(avgs [2 4 6]) -- [2.0 3.0 4.0]
(mins [3 1 2 0]) -- [3 1 1 0]
(maxs [3 1 2 5]) -- [3 3 3 5]
(sums (as 'I64 (list 0N 2 0N 4))) -- [0 2 2 6]
(avgs (as 'I64 (list 0N 2 0N 4))) -- (as 'F64 (list 0Nf 2.0 2.0 3.0))
(mins (as 'I64 (list 0N 2 0N 4))) -- (as 'I64 (list 0N 2 2 2))
(maxs (as 'I64 (list 0N 2 0N 4))) -- (as 'I64 (list 0N 2 2 4))

;; Type behaviour: integer scans widen to I64, floats produce F64,
;; min/max preserve non-float comparable storage.
(type (sums (as 'I16 [1 2 3]))) -- 'I64
(type (avgs [1 2 3])) -- 'F64
(type (mins (as 'DATE [1 2 0]))) -- 'DATE

;; differ flags row starts / value changes, including symbols and strings.
(differ [1 1 2 2 1]) -- [true false true false true]
(differ ['a 'a 'b 'b 'a]) -- [true false true false true]
(differ ["aa" "aa" "b"]) -- [true false true]

;; Query lowering: the same functions must compile inside select projections.
(set T (table [x] (list [1 1 2 2 1])))
(at (select {from: T sx: (sums x) dx: (differ x)}) 'sx) -- [1 2 4 6 7]
(at (select {from: T sx: (sums x) dx: (differ x)}) 'dx) -- [true false true false true]

;; Cross-morsel carries: more than one morsel, with nulls straddling the
;; boundary, must still produce one continuous prefix.
(count (sums (til 5000))) -- 5000
(last (sums (til 5000))) -- 12497500
(set N (concat (take (til 1100) 1024) (as 'I64 (list 0N 0N 7))))
(take (reverse (fills N)) 3) -- [7 1023 1023]
