;; Regression — println used to print "<type:-4>" / "<type:-3>" / "<type:4>"
;; for i32 / i16 / I32-vec atoms, missing the actual values.

;; Println returns null.  Use try-then-non-error to assert the call doesn't
;; itself fail.  We can't easily capture stdout from .rfl, but the format
;; logic is exercised end-to-end via the show fallback path: ensure show
;; renders these types correctly (println now uses the same fallback).
(format "%" 5i)  -- "5"
(format "%" 5h)  -- "5"
(format "%" [5i 6i 7i])  -- "[5 6 7]"
(format "%" [5h 6h 7h])  -- "[5 6 7]"
(format "%" [1.5 2.5])   -- "[1.5 2.5]"
