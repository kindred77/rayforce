;; Branch coverage for src/io/csv.c — targets reachable functional branches
;; left uncovered by csv_types.rfl, csv_round2.rfl, csv_splayed.rfl,
;; system/{read,write}_csv.rfl, and test/test_csv.c.
;;
;; Every fixture is written via .sys.exec printf (exit 0 asserted so a stale
;; file can't false-pass), every assertion is deterministic.  Fixtures use the
;; rf_test_csvbc_* prefix so the Makefile `rm -f rf_test_*.csv` rule keeps the
;; tree clean; the few directories we create are removed in the header + footer.
;;
;; Targets (csv.c line refs approximate):
;;   detect_type numeric scan : exponent sign (182), trailing junk → STR (185/223),
;;                              negative numbers, double-dot, bare sign/exponent
;;   promote_csv_type         : obs==UNKNOWN after cur set (228), I64→F64 widen (238)
;;   fast_f64 inf/-inf parse  : ray_parse_f64 inf path → 0Nf null (Stage 2 model)
;;   csv_write_time sign      : 2503-2510 — negative ms-of-day → leading "-"
;;   csv_write_timestamp neg  : 2523 — pre-2000 ns_in<0 day-borrow fixup
;;   csv_write_date pre-epoch : 2485+ — negative day count
;;   fast_time frac truncate  : 441 — >3 fractional digits, digits<3 guard stops
;;   fast_time_ns frac trunc  : 469 — >9 fractional digits truncated
;;   csv_write_str newline    : 2461 — embedded \n forces quoting on write
;;   n_rows==0 empty table    : 1526 — header-only file → empty cols
;;   single-column (no delim) : ncols==1 path, delimiter auto-detect default ','
;;   scan_field_quoted EOF    : 303-316 — unterminated quote at buf end

;; ── scrub stale state ────────────────────────────────────────────────────────
(.sys.exec "rm -rf rf_test_csvbc_parted rf_test_csvbc_splayed") -- 0
(.sys.exec "rm -f rf_test_csvbc_*.csv") -- 0

;; ════════════════════════════════════════════════════════════════════════════
;; 1. detect_type numeric scan — exponent with explicit sign (line 182).
;;    "1e+5" and "2.5e-3" must scan as F64 (has_e, then sign consume).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'x\n1e+5\n2.5e-3\n1E-2\n3.14\n' > rf_test_csvbc_sci.csv") -- 0
(set Tsci (.csv.read "rf_test_csvbc_sci.csv"))
(count Tsci) -- 4
(type (at Tsci 'x)) -- 'F64
(at (at Tsci 'x) 0) -- 100000.0
;; The exponent-sign branch is the point of this section: assert the two
;; signed-exponent rows by value, not just row 0.
(at (at Tsci 'x) 1) -- 0.0025
(at (at Tsci 'x) 2) -- 0.01
(at (at Tsci 'x) 3) -- 3.14

;; ════════════════════════════════════════════════════════════════════════════
;; 2. detect_type — trailing junk after a numeric prefix → STR (break at 185,
;;    p != end so falls through to the STR return at 223).  "12abc", "1.2.3"
;;    (second dot terminates the scan), "1e" (exponent with no digits but
;;    has_digit already true → still consumed as far as 'e', then 'e' is the
;;    last char so p<end fails → STR).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'x\n12abc\n1.2.3\nhello\n42\n' > rf_test_csvbc_junk.csv") -- 0
(set Tjunk (.csv.read "rf_test_csvbc_junk.csv"))
(count Tjunk) -- 4
;; mixed numeric-looking + words → column is a SYM (low cardinality string).
;; "42" was numeric in inference but the column widened to STR, so it is
;; interned as the symbol "42".  Compare against the equivalent SYM vector.
(type (at Tjunk 'x)) -- 'SYM
(at Tjunk 'x) -- (as 'SYMBOL ["12abc" "1.2.3" "hello" "42"])

;; ════════════════════════════════════════════════════════════════════════════
;; 3. detect_type — negative integers and floats (leading '-' at line 174).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'i,f\n-5,-1.5\n-10,-2.5\n-15,-3.5\n' > rf_test_csvbc_neg.csv") -- 0
(set Tneg (.csv.read "rf_test_csvbc_neg.csv"))
(count Tneg) -- 3
(type (at Tneg 'i)) -- 'I64
(type (at Tneg 'f)) -- 'F64
(sum (at Tneg 'i)) -- -30
(sum (at Tneg 'f)) -- -7.5

;; ════════════════════════════════════════════════════════════════════════════
;; 4. detect_type — bare sign / bare 'e' with no digits → STR (has_digit=false
;;    at line 187 so the numeric return is skipped).  "-", "+", "e5", "." (the
;;    bare-dot null sentinel collapses to UNKNOWN, the others stay STR).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'x\n-\n+\ne5\nfoo\n' > rf_test_csvbc_baresign.csv") -- 0
(set Tbs (.csv.read "rf_test_csvbc_baresign.csv"))
(count Tbs) -- 4
(type (at Tbs 'x)) -- 'SYM
;; "-", "+", "e5", "foo" all fail the numeric scan (no digits / trailing junk)
;; and intern as plain symbols.
(at Tbs 'x) -- (as 'SYMBOL ["-" "+" "e5" "foo"])

;; ════════════════════════════════════════════════════════════════════════════
;; 5. promote_csv_type — leading nulls then a value (obs after cur, and the
;;    obs==UNKNOWN early-return at line 228 for the trailing null rows).
;;    First rows are null sentinels (UNKNOWN), then I64 establishes the type,
;;    then more null sentinels keep it I64.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'v\n\n\n42\n\n7\n' > rf_test_csvbc_leadnull.csv") -- 0
(set Tln (.csv.read [I64] "rf_test_csvbc_leadnull.csv"))
(count Tln) -- 5
(nil? (at (at Tln 'v) 0)) -- true
(nil? (at (at Tln 'v) 1)) -- true
(at (at Tln 'v) 2) -- 42
(nil? (at (at Tln 'v) 3)) -- true
(at (at Tln 'v) 4) -- 7
(sum (at Tln 'v)) -- 49

;; ════════════════════════════════════════════════════════════════════════════
;; 6. promote_csv_type — I64 seen first, then F64 widens the column (line 238).
;;    Row order matters: integer rows precede the float row so `cur` is I64
;;    when the F64 observation arrives.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'v\n1\n2\n3\n4.5\n' > rf_test_csvbc_i2f.csv") -- 0
(set Ti2f (.csv.read "rf_test_csvbc_i2f.csv"))
(count Ti2f) -- 4
(type (at Ti2f 'v)) -- 'F64
(sum (at Ti2f 'v)) -- 10.5

;; ════════════════════════════════════════════════════════════════════════════
;; 7. fast_f64 inf / -inf parse  (STAGE 2 single-null float model re-baseline).
;;    The F64 domain is {finite} ∪ {0Nf}; ±Inf and NaN are NOT values.  The
;;    explicit [F64] schema still parses the "inf"/"-inf" tokens, but each
;;    canonicalizes to NULL_F64 (0Nf) at ingest — they read back as nil? and
;;    set HAS_NULLS, exactly like the empty 4th cell.  1.5 stays finite.
;;    (Was: "inf"/"-inf" loaded as real non-null infinities and round-tripped
;;    as the literal text "inf"/"-inf"; that contradicted the closed model.)
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'x\ninf\n-inf\n1.5\n\n' > rf_test_csvbc_inf.csv") -- 0
(set Tinf (.csv.read [F64] "rf_test_csvbc_inf.csv"))
(count Tinf) -- 4
;; inf and -inf now canonicalize to 0Nf → null; 1.5 finite; empty cell null.
(nil? (at (at Tinf 'x) 0)) -- true
(nil? (at (at Tinf 'x) 1)) -- true
(at (at Tinf 'x) 2) -- 1.5
(nil? (at (at Tinf 'x) 3)) -- true
;; Write back: every null F64 (rows 0,1,3) emits an empty field; only the
;; finite 1.5 prints.  No column can hold an Inf, so the old isinf write
;; branch never fires for ingested data.  Assert on the exact bytes.
(.csv.write Tinf "rf_test_csvbc_inf_out.csv") -- 0
(read "rf_test_csvbc_inf_out.csv") -- "x\n\n\n1.5\n\n"

;; ════════════════════════════════════════════════════════════════════════════
;; 8. csv_write_time — negative ms-of-day (leading '-', lines 2503-2510) and
;;    the fractional sub-branch (frac != 0 → "%02u:%02u:%02u.%03u").
;;    A TIME atom holds signed ms-of-day; negative durations render with '-'.
;; ════════════════════════════════════════════════════════════════════════════
(set Ttm (table [t] (list (as 'TIME [-3723000 3723500 0]))))
(.csv.write Ttm "rf_test_csvbc_negtime.csv") -- 0
(set linesTm (split (read "rf_test_csvbc_negtime.csv") "\n"))
(count linesTm) -- 5
(at linesTm 0) -- "t"
;; -3723000 ms = -(01:02:03) → "-01:02:03"
(at linesTm 1) -- "-01:02:03"
;; 3723500 ms = 01:02:03.500 → fractional branch
(at linesTm 2) -- "01:02:03.500"
(at linesTm 3) -- "00:00:00"

;; ════════════════════════════════════════════════════════════════════════════
;; 9. csv_write_date pre-epoch + csv_write_timestamp negative ns_in<0 fixup
;;    (line 2523).  1999-12-31 is day -1; a pre-2000 timestamp has ns<0 so the
;;    day-borrow branch fires.  Round-trip read recovers the original atoms.
;; ════════════════════════════════════════════════════════════════════════════
(set Tpre (table [d ts] (list (as 'DATE [1999.12.31 2000.01.01]) [1999.12.31D23:30:45.000000000 2000.01.02D00:00:00.000000000])))
(.csv.write Tpre "rf_test_csvbc_pre.csv") -- 0
(set linesPre (split (read "rf_test_csvbc_pre.csv") "\n"))
(at linesPre 0) -- "d,ts"
(at linesPre 1) -- "1999-12-31,1999-12-31T23:30:45"
(at linesPre 2) -- "2000-01-01,2000-01-02T00:00:00"
;; Round-trip the pre-epoch values back into typed columns.
(set Rpre (.csv.read [DATE TIMESTAMP] "rf_test_csvbc_pre.csv"))
(at (at Rpre 'd) 0) -- 1999.12.31
(at (at Rpre 'ts) 0) -- 1999.12.31D23:30:45.000000000

;; ════════════════════════════════════════════════════════════════════════════
;; 10. fast_time fractional digit handling — >3 digits truncates to ms
;;     (the `digits < 3` loop guard at line 441 stops early), and the
;;     fast_time_ns >9-digit truncation (line 469) for timestamps.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 't\n10:30:45.123456\n10:30:45.1\n' > rf_test_csvbc_tfrac.csv") -- 0
(set Ttf (.csv.read [TIME] "rf_test_csvbc_tfrac.csv"))
(count Ttf) -- 2
;; .123456 truncates to .123 ms; .1 pads to .100
(at (at Ttf 't) 0) -- 10:30:45.123
(at (at Ttf 't) 1) -- 10:30:45.100
(.sys.exec "printf 'ts\n2000-01-01T00:00:00.1234567899\n' > rf_test_csvbc_tsfrac.csv") -- 0
(set Ttsf (.csv.read [TIMESTAMP] "rf_test_csvbc_tsfrac.csv"))
(count Ttsf) -- 1
;; 10 fractional digits → first 9 kept (123456789), 10th dropped.
(at (at Ttsf 'ts) 0) -- 2000.01.01D00:00:00.123456789

;; ════════════════════════════════════════════════════════════════════════════
;; 11. csv_write_str — embedded newline forces quoting (line 2461 '\n' branch).
;;     Round-trip: the quoted field with an embedded \n survives (slow-path
;;     row scanner treats the inner \n as part of one logical row).
;; ════════════════════════════════════════════════════════════════════════════
(set Tnl (table [k v] (list [1 2] (list "a\nb" "plain"))))
(.csv.write Tnl "rf_test_csvbc_strnl.csv") -- 0
;; Exact bytes: the first value is quoted because it contains a newline.
(read "rf_test_csvbc_strnl.csv") -- "k,v\n1,\"a\nb\"\n2,plain\n"
(set Rnl (.csv.read [I64 STR] "rf_test_csvbc_strnl.csv"))
(count Rnl) -- 2
(at (at Rnl 'v) 0) -- "a\nb"
(at (at Rnl 'v) 1) -- "plain"

;; ════════════════════════════════════════════════════════════════════════════
;; 12. Header-only file → n_rows==0 empty-table path (line 1526).
;;     The data section is empty, so build_row_offsets returns 0 and the
;;     reader produces a table of empty F64 columns named by the header.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'a,b,c\n' > rf_test_csvbc_hdronly.csv") -- 0
(set Th (.csv.read "rf_test_csvbc_hdronly.csv"))
(count Th) -- 0
(key Th) -- ['a 'b 'c]

;; ════════════════════════════════════════════════════════════════════════════
;; 13. Single-column file (no delimiter anywhere) — ncols stays 1, delimiter
;;     auto-detect sees 0 commas / 0 tabs and defaults to ',' (line 1468).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'only\n10\n20\n30\n' > rf_test_csvbc_single.csv") -- 0
(set Tone (.csv.read "rf_test_csvbc_single.csv"))
(count Tone) -- 3
(key Tone) -- ['only]
(sum (at Tone 'only)) -- 60

;; ════════════════════════════════════════════════════════════════════════════
;; 14. Unterminated quoted field at end of buffer (scan_field_quoted loop runs
;;     to buf_end without a closing quote, lines 303-316).  The final field is
;;     opened with a quote but the file ends before the closing quote.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'a,b\n1,\"unterminated' > rf_test_csvbc_unterm.csv") -- 0
(set Tu (.csv.read [I64 STR] "rf_test_csvbc_unterm.csv"))
(count Tu) -- 1
(at (at Tu 'a) 0) -- 1
(at (at Tu 'b) 0) -- "unterminated"

;; ════════════════════════════════════════════════════════════════════════════
;; 15. promote_csv_type DATE+DATE keeps DATE (cur==obs early return, line 229)
;;     and pure all-bool column resolves to BOOL (csv_resolve_inferred_type).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'd,flag\n2020-01-01,true\n2020-06-15,false\n2021-12-31,true\n' > rf_test_csvbc_datebool.csv") -- 0
(set Tdb (.csv.read "rf_test_csvbc_datebool.csv"))
(count Tdb) -- 3
(at (at Tdb 'd) 0) -- 2020.01.01
(at (at Tdb 'flag) 0) -- true
(at (at Tdb 'flag) 1) -- false
(type (at Tdb 'flag)) -- 'B8

;; ════════════════════════════════════════════════════════════════════════════
;; 16. .csv.parted with explicit narrow-int schema (U8/I16/I32 parse-and-narrow
;;     arms in csv_materialize_rows + csv_parse_serial), driven through the
;;     parted writer so the chunk/materialize loop is exercised.  The
;;     [names][types] form sets header=false, so the fixture is header-less.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf '1,100,1000\n2,200,2000\n3,300,3000\n' > rf_test_csvbc_narrow.csv") -- 0
(set Rnarrow (.csv.parted [u h w] [U8 I16 I32] "rf_test_csvbc_narrow.csv" "rf_test_csvbc_parted" 'nt))
(count Rnarrow) -- 3
(sum (at Rnarrow 'u)) -- 6
(sum (at Rnarrow 'h)) -- 600
(sum (at Rnarrow 'w)) -- 6000
;; max/min confirm the narrow-int values survived parse + parted round-trip.
(max (at Rnarrow 'u)) -- (as 'U8 3)
(min (at Rnarrow 'h)) -- (as 'I16 100)
(max (at Rnarrow 'w)) -- (as 'I32 3000)

;; ════════════════════════════════════════════════════════════════════════════
;; 17. .csv.splayed with narrow-int + null-bearing columns — exercises the
;;     splayed writer's non-SYM fixed-width append path plus HAS_NULLS footer.
;;     The explicit [names][types] form sets header=false, so the fixture is
;;     header-less and column names come from the [a b] names vector.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf '1,10\n,20\n3,\n' > rf_test_csvbc_spn.csv") -- 0
(set Tspn (.csv.splayed [a b] [I16 I32] "rf_test_csvbc_spn.csv" "rf_test_csvbc_splayed"))
(count Tspn) -- 3
(nil? (at (at Tspn 'a) 1)) -- true
(nil? (at (at Tspn 'b) 2)) -- true
(sum (at Tspn 'a)) -- 4
(sum (at Tspn 'b)) -- 30
;; Re-load from disk recovers the sentinel-encoded nulls + HAS_NULLS footer.
(set Rspn (.db.splayed.get "rf_test_csvbc_splayed"))
(count Rspn) -- 3
(nil? (at (at Rspn 'a) 1)) -- true
(nil? (at (at Rspn 'b) 2)) -- true

;; ════════════════════════════════════════════════════════════════════════════
;; 18. Parallel parse path (csv_parse_fn) — non-null type arms.
;;     ray_read_csv_named_opts dispatches csv_parse_fn on the thread pool only
;;     when n_rows > 8192.  A 9000-row file with an explicit all-types schema
;;     drives the BOOL/U8/I64/F64 arms (lines ~959-1001) that the serial path
;;     leaves uncovered.  CRLF line endings additionally exercise the trailing
;;     "\r" strip on the last field of each row (line ~955).
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "awk 'BEGIN{printf \"b,u,n,f\\r\\n\"; for(i=1;i<=9000;i++){printf \"true,%d,%d,%d.5\\r\\n\", i%200, i, i}}' > rf_test_csvbc_pbig.csv") -- 0
(set Tpb (.csv.read [B8 U8 I64 F64] "rf_test_csvbc_pbig.csv"))
(count Tpb) -- 9000
(at (at Tpb 'b) 0) -- true
(at (at Tpb 'u) 0) -- (as 'U8 1)
(at (at Tpb 'n) 0) -- 1
(at (at Tpb 'f) 0) -- 1.5
;; last row survives the CRLF strip intact
(at (at Tpb 'n) 8999) -- 9000
(at (at Tpb 'f) 8999) -- 9000.5

;; ════════════════════════════════════════════════════════════════════════════
;; 19. Parallel parse path (csv_parse_fn) — DATE/TIME/TIMESTAMP/GUID/I16/I32
;;     non-null arms plus the empty-cell null arms for each (the `is_null`
;;     branches at lines ~986/993/1006/1013/1020/1028 and the STR flen==0
;;     branch at ~1035).  Every 7th row is all-empty so each nullable column
;;     records a null in the parallel worker.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "awk 'BEGIN{print \"h,w,d,t,ts,g,s\"; for(i=1;i<=9000;i++){ if(i%7==0){print \",,,,,,\"} else {printf \"%d,%d,2020-01-01,10:30:45,2020-01-01T10:30:45,00000000-0000-0000-0000-000000000001,str%d\\n\", i%30000, i, i%100} } }' > rf_test_csvbc_pnull.csv") -- 0
(set Tpn (.csv.read [I16 I32 DATE TIME TIMESTAMP GUID STR] "rf_test_csvbc_pnull.csv"))
(count Tpn) -- 9000
;; row 6 (i==7) is the first all-empty row → null in every nullable column
(nil? (at (at Tpn 'h) 6)) -- true
(nil? (at (at Tpn 'w) 6)) -- true
(nil? (at (at Tpn 'd) 6)) -- true
(nil? (at (at Tpn 't) 6)) -- true
(nil? (at (at Tpn 'ts) 6)) -- true
;; non-empty rows keep their parsed values
(at (at Tpn 'h) 0) -- (as 'I16 1)
(at (at Tpn 'w) 0) -- (as 'I32 1)
(at (at Tpn 'd) 0) -- 2020.01.01
(at (at Tpn 't) 0) -- 10:30:45.000

;; ════════════════════════════════════════════════════════════════════════════
;; 20. Short-row guard (csv_parse_serial line ~1087): a data row with fewer
;;     fields than ncols.  Once scan_field walks past row_end, the remaining
;;     columns are filled with type defaults + null (nullable types) so the
;;     row count is preserved and downstream columns stay aligned.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "printf 'a,b,c\n1,2,3\n9\n4,5,6\n' > rf_test_csvbc_short.csv") -- 0
(set Tsh (.csv.read [I64 I64 I64] "rf_test_csvbc_short.csv"))
(count Tsh) -- 3
(at (at Tsh 'a) 1) -- 9
(nil? (at (at Tsh 'b) 1)) -- true
(nil? (at (at Tsh 'c) 1)) -- true
;; full rows on either side are unaffected
(at (at Tsh 'c) 0) -- 3
(at (at Tsh 'a) 2) -- 4

;; ════════════════════════════════════════════════════════════════════════════
;; 21. .csv.parted trace branches (ray_csv_save_parted_named_opts, lines
;;     ~2410-2553 guarded by getenv("RAY_CSV_TRACE")).  Enabling the env var
;;     exercises the per-stage stderr trace prints; rows_per_part=2 over 3 rows
;;     forces a two-part split so the per-part save trace fires more than once.
;; ════════════════════════════════════════════════════════════════════════════
(.os.setenv "RAY_CSV_TRACE" "1") -- "1"
(.sys.exec "rm -rf rf_test_csvbc_pttrace") -- 0
(.sys.exec "printf 'a,b\n1,10\n2,20\n3,30\n' > rf_test_csvbc_pttrace.csv") -- 0
(set Rpt (.csv.parted "rf_test_csvbc_pttrace.csv" 2 "rf_test_csvbc_pttrace" 'tbl))
(count Rpt) -- 3
(sum (at Rpt 'a)) -- 6
(sum (at Rpt 'b)) -- 60
(.os.setenv "RAY_CSV_TRACE" "") -- ""
(.sys.exec "rm -rf rf_test_csvbc_pttrace") -- 0

;; ════════════════════════════════════════════════════════════════════════════
;; 22. Chunk-zone + hash-index attach (ray_read_csv_named_opts lines ~1937-1945):
;;     a numeric column only gets a per-chunk zone index once its length reaches
;;     one chunk (65536 rows); high-entropy values then upgrade to a hash index
;;     (csv_should_attach_hash).  A 70000-row pseudo-random I64 column crosses
;;     both thresholds.  Spot-check aggregates so the index attach can't quietly
;;     corrupt the payload.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "awk 'BEGIN{print \"id\"; for(i=1;i<=70000;i++) print (i*2654435761)%2000000000}' > rf_test_csvbc_zone.csv") -- 0
(set Tz (.csv.read [I64] "rf_test_csvbc_zone.csv"))
(count Tz) -- 70000
(type (at Tz 'id)) -- 'I64
;; first value: (1*2654435761) % 2000000000 = 654435761
(at (at Tz 'id) 0) -- 654435761

;; ════════════════════════════════════════════════════════════════════════════
;; 23. Parallel materialize path (csv_materialize_rows lines ~1409-1442): the
;;     parted/splayed writers materialize each chunk through csv_materialize_rows,
;;     which dispatches csv_parse_fn on the pool when the chunk exceeds 8192 rows.
;;     The default rows-per-part (1e6) keeps a 9000-row file in a single chunk so
;;     the whole batch goes through the parallel branch.  An inferred SYM column
;;     ("str%50") also exercises the sym-narrow path inside the materializer.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "rm -rf rf_test_csvbc_mr") -- 0
(.sys.exec "awk 'BEGIN{print \"n,s\"; for(i=1;i<=9000;i++){printf \"%d,str%d\\n\", i, i%50}}' > rf_test_csvbc_mr.csv") -- 0
(set Rmr (.csv.parted "rf_test_csvbc_mr.csv" "rf_test_csvbc_mr" 'tbl))
(count Rmr) -- 9000
;; sum 1..9000 = 9000*9001/2 = 40504500
(sum (at Rmr 'n)) -- 40504500
;; the inferred string column round-trips back (parted reload prepends 'part)
(key Rmr) -- ['part 'n 's]

;; ════════════════════════════════════════════════════════════════════════════
;; 24. Parallel materialize through the splayed writer (csv_splayed_writer_append
;;     SYM + fixed-width arms over a 9000-row chunk).  The inferred SYM column
;;     forces the W32 sym-buffer append loop; the numeric column drives the
;;     fixed-width fwrite arm.  Re-load from disk confirms the round trip.
;; ════════════════════════════════════════════════════════════════════════════
(.sys.exec "rm -rf rf_test_csvbc_mrsp") -- 0
(.sys.exec "awk 'BEGIN{print \"n,s\"; for(i=1;i<=9000;i++){printf \"%d,str%d\\n\", i, i%50}}' > rf_test_csvbc_mrsp.csv") -- 0
(set Rsp (.csv.splayed "rf_test_csvbc_mrsp.csv" "rf_test_csvbc_mrsp"))
(count Rsp) -- 9000
(set Rspget (.db.splayed.get "rf_test_csvbc_mrsp"))
(count Rspget) -- 9000
(sum (at Rspget 'n)) -- 40504500
(key Rspget) -- ['n 's]

;; ── cleanup ──────────────────────────────────────────────────────────────────
(.sys.exec "rm -f rf_test_csvbc_*.csv") -- 0
(.sys.exec "rm -rf rf_test_csvbc_parted rf_test_csvbc_splayed rf_test_csvbc_pttrace rf_test_csvbc_mr rf_test_csvbc_mrsp") -- 0
